{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "Deployment-aware PAN and MnT node health, capacity, load, resource utilization, diagnostics, certificates, backup, and bounded active-session latency.",
  "panels": [
    {
      "id": 90,
      "type": "stat",
      "title": "Deployment Dataset",
      "description": "Authoritative PAN deployment and node-role snapshot availability.",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"})",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "links": [
            {"title": "Inspect deployment dataset", "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=deployment&var-source=rest", "targetBlank": false}
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 91,
      "type": "stat",
      "title": "Deployment Snapshot Age",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"})",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 450}, {"color": "red", "value": 600}]}
        },
        "overrides": []
      }
    },
    {
      "id": 92,
      "type": "stat",
      "title": "MnT Active Dataset",
      "description": "Availability of the bounded current active-session posture snapshot from MnT XML.",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"})",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "links": [
            {"title": "Inspect MnT dataset", "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=mnt_active_posture&var-source=mnt", "targetBlank": false}
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 93,
      "type": "stat",
      "title": "MnT Snapshot Age",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"})",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 450}, {"color": "red", "value": 600}]}
        },
        "overrides": []
      }
    },
    {
      "id": 94,
      "type": "stat",
      "title": "Node Performance Dataset",
      "description": "Data Connect node capacity, reporting, and diagnostic snapshot availability.",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "links": [
            {"title": "Inspect performance dataset", "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=dataconnect_performance&var-source=dataconnect", "targetBlank": false}
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 95,
      "type": "stat",
      "title": "Node Performance Age",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 450}, {"color": "red", "value": 600}]}
        },
        "overrides": []
      }
    },
    {
      "id": 1,
      "type": "row",
      "title": "Policy Administration Nodes",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 4},
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PAN HA Enabled",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 5},
      "targets": [
        {
          "expr": "ise_pan_ha_enabled{instance=~\"$deployment\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DISABLED", "color": "yellow"}, "1": {"text": "ENABLED", "color": "green"}}}
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connected PANs",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 5},
      "targets": [
        {
          "expr": "(count(ise_deployment_status{instance=~\"$deployment\",node=~\"$pan\",roles=~\".*(PrimaryAdmin|SecondaryAdmin|Standalone).*\",ise_deployment_status=\"Connected\"} == 1) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1))) or on() (0 * ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Backup Age",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "ise_backup_age_hours{instance=~\"$deployment\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"backup\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"backup\",source=\"rest\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "h"}, "overrides": []}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Patch Level",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 5},
      "targets": [
        {
          "expr": "ise_patch_level{instance=~\"$deployment\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"patches\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"patches\",source=\"rest\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "PAN Node Status",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "targets": [
        {
          "expr": "(ise_deployment_status{instance=~\"$deployment\",node=~\"$pan\",roles=~\".*(PrimaryAdmin|SecondaryAdmin|Standalone).*\"} == 1) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "options": {"showHeader": true},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true}}}
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "PAN Service Assignments",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "targets": [
        {
          "expr": "(ise_node_service_enabled{instance=~\"$deployment\",node=~\"$pan\"} == 1) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "options": {"showHeader": true},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true}}}
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "PAN Certificate Expiry",
      "description": "System and trusted certificates whose hostname matches the selected PAN nodes, ordered by remaining lifetime.",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 18},
      "targets": [
        {
          "expr": "sort(ise_certificate_expiry_days{instance=~\"$deployment\",hostname=~\"$pan\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"certificates\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"certificates\",source=\"rest\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "d"}, "overrides": []},
      "options": {"showHeader": true},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true}, "renameByName": {"Value": "days"}}}
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Monitoring and Troubleshooting Nodes",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 28},
      "panels": []
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Connected MnTs",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 29},
      "targets": [
        {
          "expr": "(count(ise_deployment_status{instance=~\"$deployment\",node=~\"$mnt\",roles=~\".*(PrimaryDedicatedMonitoring|PrimaryMonitoring|SecondaryDedicatedMonitoring|SecondaryMonitoring|Standalone).*\",ise_deployment_status=\"Connected\"} == 1) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1))) or on() (0 * ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "MnT Active Sessions",
      "description": "Active sessions reported by the bounded MnT ActiveList collection.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 29},
      "targets": [
        {
          "expr": "ise_mnt_active_sessions_total{instance=~\"$deployment\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "MnT Detail Coverage",
      "description": "Successful MnT session-detail lookups divided by selected active endpoints, over time. Budget-bound: each 5-minute cycle fetches up to mnt_active_posture.max_requests_per_cycle (default 80) details, so under heavy session churn or when active sessions exceed the 1000 selection ceiling the ratio plateaus below 100%. Raise max_requests_per_cycle (max 250) and/or refresh_ttl to lift it.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 29},
      "targets": [
        {
          "expr": "ise_mnt_active_posture_detail_coverage_ratio{instance=~\"$deployment\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": false,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "MnT Detail Truncated",
      "description": "TRUNCATED means the number of currently active sessions exceeded the configured selection ceiling (mnt_active_posture.max_sessions, capped at 1000), so posture detail was collected for only the first 1000 active endpoints and coverage reflects that subset. COMPLETE means every active session was in scope.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 29},
      "targets": [
        {
          "expr": "ise_mnt_active_posture_detail_truncated{instance=~\"$deployment\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "COMPLETE", "color": "green"}, "1": {"text": "TRUNCATED", "color": "yellow"}}}
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "table",
      "title": "MnT Node Status",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 33},
      "targets": [
        {
          "expr": "(ise_deployment_status{instance=~\"$deployment\",node=~\"$mnt\",roles=~\".*(PrimaryDedicatedMonitoring|PrimaryMonitoring|SecondaryDedicatedMonitoring|SecondaryMonitoring|Standalone).*\"} == 1) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"deployment\",source=\"rest\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "options": {"showHeader": true},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true}}}
      ]
    },
    {
      "id": 15,
      "type": "bargauge",
      "title": "Active Endpoints by Serving PSN",
      "description": "Bounded MnT detail sample grouped by the PSN recorded on each active session.",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 33},
      "targets": [
        {
          "expr": "sort_desc(sum by (psn) (ise_mnt_active_posture_endpoints{instance=~\"$deployment\"})) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "legendFormat": "{{psn}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        },
        "overrides": []
      },
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "showUnfilled": true}
    },
    {
      "id": 16,
      "type": "row",
      "title": "PAN and MnT Node Performance",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 42},
      "panels": []
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Node Load",
      "description": "Average and maximum load reported by Data Connect for the selected PAN and MnT nodes.",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 43},
      "targets": [
        {
          "expr": "ise_dataconnect_psn_load_percent{instance=~\"$deployment\",node=~\"$pan|$mnt\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "{{node}} / {{stat}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []}
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "CPU Utilization",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 43},
      "targets": [
        {
          "expr": "ise_dataconnect_node_cpu_utilization_percent{instance=~\"$deployment\",node=~\"$pan|$mnt\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []}
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Memory Utilization",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 43},
      "targets": [
        {
          "expr": "ise_dataconnect_node_memory_utilization_percent{instance=~\"$deployment\",node=~\"$pan|$mnt\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}, "overrides": []}
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "Highest Disk Utilization per PAN/MnT",
      "description": "Highest reported partition utilization on each selected PAN or MnT, collapsed to one bar per node.",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 51},
      "targets": [
        {
          "expr": "sort_desc(max by (node) (ise_dataconnect_node_disk_utilization_percent{instance=~\"$deployment\",node=~\"$pan|$mnt\"})) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}
        },
        "overrides": []
      },
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "showUnfilled": true}
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Reporting Logs, Noise, and Suppression",
      "description": "ISE reporting-pipeline counters for the selected PAN and MnT nodes.",
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 51},
      "targets": [
        {
          "expr": "ise_dataconnect_psn_mnt_logs_per_hour{instance=~\"$deployment\",node=~\"$pan|$mnt\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "logs / {{node}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "expr": "ise_dataconnect_psn_noise_per_hour{instance=~\"$deployment\",node=~\"$pan|$mnt\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "noise / {{node}}",
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        },
        {
          "expr": "ise_dataconnect_psn_suppression_per_hour{instance=~\"$deployment\",node=~\"$pan|$mnt\"} and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "suppressed / {{node}}",
          "refId": "C",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ]
    },
    {
      "id": 23,
      "type": "table",
      "title": "PAN and MnT Diagnostic Work Queue",
      "description": "Highest-volume AAA and system diagnostics for the selected PAN and MnT nodes.",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 59},
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_diagnostic_events{instance=~\"$deployment\",node=~\"$pan|$mnt\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "options": {"showHeader": true, "footer": {"show": true, "reducer": ["sum"]}},
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true}, "renameByName": {"Value": "events"}}}
      ]
    },
    {
      "id": 24,
      "type": "row",
      "title": "MnT Active Session Latency (PSN-measured, read from MnT)",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 71},
      "panels": []
    },
    {
      "id": 25,
      "type": "bargauge",
      "title": "Total Authentication Latency",
      "description": "Average and maximum TotalAuthenLatency across the bounded active-session detail sample. These latencies are measured on the PSN that authenticated each session — MnT is only the reporting store the exporter reads them from. MnT nodes do not perform authentication.",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 72},
      "targets": [
        {
          "expr": "sort_desc(ise_mnt_active_total_authentication_latency_seconds{instance=~\"$deployment\",stat=~\"avg|max\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "legendFormat": "{{stat}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "showUnfilled": true}
    },
    {
      "id": 26,
      "type": "bargauge",
      "title": "Authentication Step Latency",
      "description": "Average and maximum latency by numeric ISE authentication step code, measured on the authenticating PSN and read from MnT session detail.",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 72},
      "targets": [
        {
          "expr": "sort_desc(ise_mnt_active_step_latency_seconds{instance=~\"$deployment\",stat=~\"avg|max\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "legendFormat": "step {{step}} / {{stat}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "showUnfilled": true}
    },
    {
      "id": 27,
      "type": "bargauge",
      "title": "Authentication Step Samples",
      "description": "Number of valid latency samples behind each authentication step aggregate.",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 72},
      "targets": [
        {
          "expr": "sort_desc(ise_mnt_active_step_latency_samples{instance=~\"$deployment\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "legendFormat": "step {{step}}",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
        }
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "showUnfilled": true}
    },
    {
      "id": 28,
      "type": "stat",
      "title": "MnT ActiveList Safety",
      "description": "ActiveCount preflight, configured unpaged-list ceiling, and whether collection was refused.",
      "gridPos": {"h": 5, "w": 12, "x": 0, "y": 79},
      "targets": [
        {"expr": "ise_mnt_session_list_preflight_count{instance=~\"$deployment\"}", "instant": true, "legendFormat": "active sessions", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_mnt_session_list_ceiling{instance=~\"$deployment\"}", "instant": true, "legendFormat": "download ceiling", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_mnt_session_list_skipped{instance=~\"$deployment\"}", "instant": true, "legendFormat": "list refused", "refId": "C", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}},
        "overrides": []
      },
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "id": 29,
      "type": "table",
      "title": "PAN and MnT Collector Health",
      "gridPos": {"h": 5, "w": 12, "x": 12, "y": 79},
      "targets": [
        {"expr": "time() - ise_last_successful_scrape_timestamp{instance=~\"$deployment\",collector=~\"deployment|mnt_active_posture\"}", "format": "table", "instant": true, "legendFormat": "success age", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_consecutive_failures{instance=~\"$deployment\",collector=~\"deployment|mnt_active_posture\"}", "format": "table", "instant": true, "legendFormat": "failures", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_mnt_worker_busy{instance=~\"$deployment\"}", "format": "table", "instant": true, "legendFormat": "worker busy", "refId": "C", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "options": {"showHeader": true}
    }
  ],
