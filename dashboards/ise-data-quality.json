        {"expr": "ise_mnt_session_list_ceiling", "instant": true, "legendFormat": "download ceiling", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_mnt_session_list_skipped", "instant": true, "legendFormat": "list refused", "refId": "C", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
