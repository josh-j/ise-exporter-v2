{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "id": null,
  "uid": "ise-data-quality",
  "title": "ISE Exporter / Data Quality & Freshness",
  "tags": ["cisco", "ise", "data-quality", "dataconnect"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "description": "Collection-plan health, source-event freshness, reporting-view coverage, and top-K truncation. A successful query is separated from genuinely current source data.",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Unavailable Enabled Datasets",
      "description": "Enabled authoritative datasets whose latest collection attempt failed.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "count((ise_dataset_up == 0) and on(dataset,source) (ise_dataset_enabled == 1)) or on() (0 * (count(ise_dataset_up) > 0))",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Stale Enabled Datasets",
      "description": "Enabled datasets without a successful replacement inside twice their configured interval.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "count((ise_dataset_fresh == 0) and on(dataset,source) (ise_dataset_enabled == 1)) or on() (0 * (count(ise_dataset_up) > 0))",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Empty Reporting Views",
      "description": "Timestamped Data Connect views with no rows in the bounded two-day reporting window. Presence uses a one-row newest-event probe rather than an exact full-window count.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "(count(ise_dataconnect_view_has_rows == 0) and on() (max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1))",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Truncated Breakdowns",
      "description": "Collector dimensional breakdowns where the configured top-K limit omits groups. Exact total metrics remain authoritative.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
          "expr": "((count(ise_dataconnect_radius_topk_truncated == 1) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))) + ((ise_dataconnect_radius_active_groups_truncated and on() (max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1))) + ((count(ise_dataconnect_posture_topk_truncated == 1) and on() (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))) + ((count(ise_dataconnect_endpoint_topk_truncated == 1) and on() (max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1))) + ((count(ise_dataconnect_diagnostic_topk_truncated == 1) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))) + ((count(ise_tacacs_topk_truncated == 1) and on() (max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1))) + ((ise_tacacs_internal_user_inventory_truncated and on() (max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1)))",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 5,
      "type": "table",
      "title": "Authoritative Dataset Plan",
      "description": "Configured ownership, cadence, availability, freshness, and attempt/success timestamps for every dataset.",
      "gridPos": {"h": 11, "w": 24, "x": 0, "y": 4},
      "targets": [
        {"expr": "ise_dataset_enabled", "format": "table", "instant": true, "refId": "Enabled", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_up", "format": "table", "instant": true, "refId": "Available", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_fresh", "format": "table", "instant": true, "refId": "Fresh", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_interval_seconds", "format": "table", "instant": true, "refId": "Interval", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "time() - ise_dataset_last_attempt_timestamp", "format": "table", "instant": true, "refId": "Attempt age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "time() - ise_dataset_last_success_timestamp", "format": "table", "instant": true, "refId": "Success age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 6,
      "type": "table",
      "title": "Data Connect Source-Event Freshness",
      "description": "Row presence and newest event inside each view's two-day window. Each source probe returns at most one row; exact counts and oldest-row scans are intentionally omitted to protect MnT.",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 15},
      "targets": [
        {"expr": "ise_dataconnect_view_has_rows and on() (max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1)", "format": "table", "instant": true, "refId": "Has rows", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "(time() - (ise_dataconnect_view_newest_event_timestamp > 0)) and on() (max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1)", "format": "table", "instant": true, "refId": "Newest event age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Posture Coverage",
      "description": "Fraction of posture-applicable endpoints with a recent assessment in the bounded reporting window.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 27},
      "targets": [{"expr": "ise_dataconnect_posture_eligible_recent_assessment_ratio and on() (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Unknown Endpoint Profiles",
      "description": "Current endpoints whose profile is missing or unknown.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 27},
      "targets": [{"expr": "ise_dataconnect_endpoints_unknown_profile_total and on() (max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Endpoints Stale 90d",
      "description": "Current endpoint inventory not updated during the last 90 days.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 27},
      "targets": [{"expr": "ise_dataconnect_endpoints_stale{age_days=\"90\"} and on() (max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Distinct RADIUS Users",
      "description": "Exact distinct usernames observed in the bounded RADIUS reporting window.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 27},
      "targets": [{"expr": "ise_dataconnect_radius_distinct_users_total and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Configured NADs Without Activity",
      "description": "Configured network devices with no RADIUS authentications in the reporting window.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 31},
      "targets": [{"expr": "(count(ise_nad_seen_recently == 0) and on() (max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1))", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Unconfigured NAD Events",
      "description": "RADIUS authentications attributed to device names absent from the configured ERS inventory.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 31},
      "targets": [{"expr": "ise_nad_unconfigured_authentication_events_total and on() (max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Certificate Security Findings",
      "description": "Weak-signature, self-signed, or issuer-not-present findings across collected system certificates.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 31},
      "targets": [{"expr": "((sum(ise_certificate_weak_signature) or on() (0 * (max(ise_dataset_up{dataset=\"certificates\",source=\"rest\"}) == 1))) + (sum(ise_certificate_self_signed) or on() (0 * (max(ise_dataset_up{dataset=\"certificates\",source=\"rest\"}) == 1))) + (sum(1 - ise_certificate_issuer_present_in_trust_store) or on() (0 * (max(ise_dataset_up{dataset=\"certificates\",source=\"rest\"}) == 1)))) and on() (max(ise_dataset_up{dataset=\"certificates\",source=\"rest\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Disconnected ISE Nodes",
      "description": "Deployment nodes currently reporting a disconnected state.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 31},
      "targets": [{"expr": "sum(ise_deployment_status{ise_deployment_status=\"Disconnected\"}) and on() (max(ise_dataset_up{dataset=\"deployment\",source=\"rest\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 15,
      "type": "table",
      "title": "NAD Authentication Health",
      "description": "Recent pass/fail counts, last authentication time, and activity state for every configured NAD.",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 35},
      "targets": [
        {"expr": "ise_nad_authentication_events and on() (max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1)", "format": "table", "instant": true, "refId": "Events", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_nad_seen_recently and on() (max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1)", "format": "table", "instant": true, "refId": "Seen", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "(time() - ise_nad_last_authentication_timestamp) and on() (max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1)", "format": "table", "instant": true, "refId": "Last auth age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 16,
      "type": "table",
      "title": "Certificate Bindings & Key Strength",
      "description": "Active service bindings and public-key sizes for ISE system and trusted certificates.",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 35},
      "targets": [
        {"expr": "ise_certificate_binding and on() (max(ise_dataset_up{dataset=\"certificates\",source=\"rest\"}) == 1)", "format": "table", "instant": true, "refId": "Bindings", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_certificate_key_size_bits and on() (max(ise_dataset_up{dataset=\"certificates\",source=\"rest\"}) == 1)", "format": "table", "instant": true, "refId": "Key size", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 17,
      "type": "stat",
      "title": "MnT Active Posture Dataset",
      "description": "Availability of the bounded current active-session posture collector.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 45},
      "targets": [{"expr": "max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"})", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}, "overrides": []}
    },
    {
      "id": 18,
      "type": "stat",
      "title": "MnT Active Snapshot Age",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 45},
      "targets": [{"expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"mnt_active_posture\",source=\"mnt\"})", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1350}, {"color": "red", "value": 1800}]}}, "overrides": []}
    },
    {
      "id": 19,
      "type": "stat",
      "title": "MnT Detail Coverage",
      "description": "Successful detail lookups divided by selected active endpoints.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 45},
      "targets": [{"expr": "ise_mnt_active_posture_detail_coverage_ratio and on() (max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 20,
      "type": "stat",
      "title": "MnT Detail Truncated",
      "description": "1 means candidate active endpoints exceeded the configured detail-request bound.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 45},
      "targets": [{"expr": "ise_mnt_active_posture_detail_truncated and on() (max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "COMPLETE", "color": "green"}, "1": {"text": "TRUNCATED", "color": "yellow"}}}]}, "overrides": []}
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "MnT Active Posture Field Coverage",
      "description": "Fraction of collected active endpoint details containing each posture source field.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 49},
      "targets": [{"expr": "ise_mnt_active_posture_field_coverage_ratio and on() (max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1)", "legendFormat": "{{field}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 29,
      "type": "row",
      "title": "Persistent Collection Cache",
      "description": "Restart-persistent MnT detail caching and bounded Data Connect metric snapshots.",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 57}
    },
    {
      "id": 30,
      "type": "stat",
      "title": "MnT Cached Active Details",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 58},
      "targets": [{"expr": "ise_mnt_active_posture_cache_entries and on() (max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 31,
      "type": "stat",
      "title": "MnT Refresh Requests / Deferred",
      "description": "Actual detail calls and refreshes deferred by the production request budget.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 58},
      "targets": [
        {"expr": "ise_mnt_active_posture_detail_requests and on() (max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1)", "instant": true, "legendFormat": "requested", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_mnt_active_posture_refresh_deferred and on() (max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1)", "instant": true, "legendFormat": "deferred", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Oldest Active Detail Cache Age",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 58},
      "targets": [{"expr": "ise_mnt_active_posture_cache_oldest_age_seconds and on() (max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 33,
      "type": "stat",
      "title": "RADIUS Reporting / Active Age",
      "description": "Exact historical reporting and bounded current-session reconstruction have independent collection ages.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 58},
      "targets": [
        {"expr": "(time() - ise_dataset_last_success_timestamp{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)", "instant": true, "legendFormat": "reporting age", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "(time() - ise_dataset_last_success_timestamp{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1)", "instant": true, "legendFormat": "active age", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ]
    },
    {
      "id": 22,
      "type": "row",
      "title": "Data Connect Load Safety",
      "description": "Deployment-wide query pacing, runtime, result size, and adaptive duty-cycle protection.",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 62}
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Data Connect Statements per Minute",
      "description": "Fixed reporting-view labels only; arbitrary SQL is never exported.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 63},
      "targets": [{"expr": "60 * sum by (view, result) (rate(ise_dataconnect_queries_total[5m]))", "legendFormat": "{{view}} / {{result}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "qpm"}, "overrides": []}
    },
    {
      "id": 24,
      "type": "bargauge",
      "title": "Latest Data Connect Query Duration",
      "description": "Latest completed statement latency by reporting view. This remains visible across the intentionally sparse production cadence; use the histogram metric for long-range percentile analysis.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 63},
      "targets": [{"expr": "ise_dataconnect_query_last_duration_seconds", "instant": true, "legendFormat": "{{view}} / {{result}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 25,
      "type": "table",
      "title": "Data Connect Collection Cadence",
      "description": "Scheduled domain cadence and bounded event scan windows. The client applies the per-statement duty-cycle cooldown shown below; the scheduler does not apply that delay a second time.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 71},
      "targets": [
        {"expr": "ise_dataset_interval_seconds{source=\"dataconnect\"}", "format": "table", "instant": true, "refId": "Configured", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_effective_interval_seconds{source=\"dataconnect\"}", "format": "table", "instant": true, "refId": "Scheduled", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataconnect_scan_window_hours", "format": "table", "instant": true, "refId": "Scan window hours", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 26,
      "type": "bargauge",
      "title": "Latest Data Connect Rows Returned",
      "description": "Client-side result size by fixed reporting view; a failed latest attempt publishes zero instead of retaining an older successful row count. Grouped result caps protect exporter memory and metric cardinality.",
      "gridPos": {"h": 9, "w": 9, "x": 12, "y": 71},
      "targets": [{"expr": "ise_dataconnect_query_rows", "legendFormat": "{{view}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 27,
      "type": "stat",
      "title": "Statement Pacing",
      "description": "Minimum idle time inserted between sequential Data Connect statements.",
      "gridPos": {"h": 9, "w": 3, "x": 21, "y": 71},
      "targets": [{"expr": "ise_dataconnect_query_pacing_seconds", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 28,
      "type": "bargauge",
      "title": "Latest Global Query Cooldown",
      "description": "Quiet time imposed after each view query to keep aggregate Data Connect database duty cycle within the configured ceiling.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 80},
      "targets": [{"expr": "ise_dataconnect_query_cooldown_seconds", "legendFormat": "{{view}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 34,
      "type": "stat",
      "title": "Data Connect Worker / Queue",
      "description": "One worker executes reporting domains serially. Queue depth above zero is expected during a paced cold start but should eventually drain.",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 88},
      "targets": [
        {"expr": "ise_dataconnect_worker_busy", "instant": true, "legendFormat": "busy", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataconnect_queue_depth", "instant": true, "legendFormat": "queued domains", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ]
    },
    {
      "id": 35,
      "type": "stat",
      "title": "Oldest Data Connect Queue Wait",
      "description": "Time the oldest reporting domain has waited behind the serialized duty-cycle gate.",
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 88},
      "targets": [{"expr": "ise_dataconnect_oldest_queued_seconds", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 36,
