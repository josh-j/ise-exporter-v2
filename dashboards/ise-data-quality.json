{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "id": null,
  "uid": "ise-data-quality",
  "title": "ISE Exporter / Data Quality & Freshness",
  "tags": ["cisco", "ise", "data-quality", "dataconnect"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "description": "Collection-plan health, source-event freshness, reporting-view coverage, and top-K truncation. A successful query is separated from genuinely current source data.",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Unavailable Enabled Datasets",
      "description": "Enabled authoritative datasets whose latest collection attempt failed.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "count((ise_dataset_up == 0) and on(dataset,source) (ise_dataset_enabled == 1)) or on() (0 * (count(ise_dataset_up) > 0))",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Stale Enabled Datasets",
      "description": "Enabled datasets without a successful replacement inside twice their configured interval.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "count((ise_dataset_fresh == 0) and on(dataset,source) (ise_dataset_enabled == 1)) or on() (0 * (count(ise_dataset_up) > 0))",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Empty Reporting Views",
      "description": "Timestamped Data Connect views with no rows in the bounded two-day reporting window.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "count(ise_dataconnect_view_rows == 0) and on() (max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1)",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Truncated Breakdowns",
      "description": "Collector dimensional breakdowns where the configured top-K limit omits groups. Exact total metrics remain authoritative.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
          "expr": "(count(ise_dataconnect_radius_topk_truncated == 1) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))) + (count(ise_dataconnect_posture_topk_truncated == 1) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))) + (count(ise_dataconnect_endpoint_topk_truncated == 1) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1)))",
        "instant": true,
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 5,
      "type": "table",
      "title": "Authoritative Dataset Plan",
      "description": "Configured ownership, cadence, availability, freshness, and attempt/success timestamps for every dataset.",
      "gridPos": {"h": 11, "w": 24, "x": 0, "y": 4},
      "targets": [
        {"expr": "ise_dataset_enabled", "format": "table", "instant": true, "refId": "Enabled", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_up", "format": "table", "instant": true, "refId": "Available", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_fresh", "format": "table", "instant": true, "refId": "Fresh", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_interval_seconds", "format": "table", "instant": true, "refId": "Interval", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "time() - ise_dataset_last_attempt_timestamp", "format": "table", "instant": true, "refId": "Attempt age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "time() - ise_dataset_last_success_timestamp", "format": "table", "instant": true, "refId": "Success age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 6,
      "type": "table",
      "title": "Data Connect Source-Event Freshness",
      "description": "Row count and event-time bounds inside each view's two-day window. Source age can increase while collection itself remains healthy.",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 15},
      "targets": [
        {"expr": "ise_dataconnect_view_rows", "format": "table", "instant": true, "refId": "Rows", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "time() - (ise_dataconnect_view_newest_event_timestamp > 0)", "format": "table", "instant": true, "refId": "Newest event age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "(ise_dataconnect_view_newest_event_timestamp - ise_dataconnect_view_oldest_event_timestamp) and on(domain,view) (ise_dataconnect_view_rows > 0)", "format": "table", "instant": true, "refId": "Window span", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Posture Coverage",
      "description": "Fraction of posture-applicable endpoints with a recent assessment in the bounded reporting window.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 27},
      "targets": [{"expr": "ise_dataconnect_posture_eligible_recent_assessment_ratio", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Unknown Endpoint Profiles",
      "description": "Current endpoints whose profile is missing or unknown.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 27},
      "targets": [{"expr": "sum(ise_dataconnect_endpoints_by_profile{profile=~\"(?i:unknown|none|missing)\"})", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Endpoints Stale 90d",
      "description": "Current endpoint inventory not updated during the last 90 days.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 27},
      "targets": [{"expr": "ise_dataconnect_endpoints_stale{age_days=\"90\"}", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Distinct RADIUS Users",
      "description": "Exact distinct usernames observed in the bounded RADIUS reporting window.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 27},
      "targets": [{"expr": "ise_dataconnect_radius_distinct_users_total", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Configured NADs Without Activity",
      "description": "Configured network devices with no RADIUS authentications in the reporting window.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 31},
      "targets": [{"expr": "count(ise_nad_seen_recently == 0)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Unconfigured NAD Events",
      "description": "RADIUS authentications attributed to device names absent from the configured ERS inventory.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 31},
      "targets": [{"expr": "ise_nad_unconfigured_authentication_events_total", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Certificate Security Findings",
      "description": "Weak-signature, self-signed, or issuer-not-present findings across collected system certificates.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 31},
      "targets": [{"expr": "sum(ise_certificate_weak_signature) + sum(ise_certificate_self_signed) + sum(1 - ise_certificate_issuer_present_in_trust_store)", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Disconnected ISE Nodes",
      "description": "Deployment nodes currently reporting a disconnected state.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 31},
      "targets": [{"expr": "sum(ise_deployment_status{ise_deployment_status=\"Disconnected\"})", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []}
    },
    {
      "id": 15,
      "type": "table",
      "title": "NAD Authentication Health",
      "description": "Recent pass/fail counts, last authentication time, and activity state for every configured NAD.",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 35},
      "targets": [
        {"expr": "ise_nad_authentication_events", "format": "table", "instant": true, "refId": "Events", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_nad_seen_recently", "format": "table", "instant": true, "refId": "Seen", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "time() - ise_nad_last_authentication_timestamp", "format": "table", "instant": true, "refId": "Last auth age", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 16,
      "type": "table",
      "title": "Certificate Bindings & Key Strength",
      "description": "Active service bindings and public-key sizes for ISE system and trusted certificates.",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 35},
      "targets": [
        {"expr": "ise_certificate_binding", "format": "table", "instant": true, "refId": "Bindings", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_certificate_key_size_bits", "format": "table", "instant": true, "refId": "Key size", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 17,
      "type": "stat",
      "title": "MnT Active Posture Dataset",
      "description": "Availability of the bounded current active-session posture collector.",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 45},
      "targets": [{"expr": "max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"})", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}, "overrides": []}
    },
    {
      "id": 18,
      "type": "stat",
      "title": "MnT Active Snapshot Age",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 45},
      "targets": [{"expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"mnt_active_posture\",source=\"mnt\"})", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 600}, {"color": "red", "value": 900}]}}, "overrides": []}
    },
    {
      "id": 19,
      "type": "stat",
      "title": "MnT Detail Coverage",
      "description": "Successful detail lookups divided by selected active endpoints.",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 45},
      "targets": [{"expr": "ise_mnt_active_posture_detail_coverage_ratio", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 20,
      "type": "stat",
      "title": "MnT Detail Truncated",
      "description": "1 means candidate active endpoints exceeded the configured detail-request bound.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 45},
      "targets": [{"expr": "ise_mnt_active_posture_detail_truncated", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "COMPLETE", "color": "green"}, "1": {"text": "TRUNCATED", "color": "yellow"}}}]}, "overrides": []}
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "MnT Active Posture Field Coverage",
      "description": "Fraction of collected active endpoint details containing each posture source field.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 49},
      "targets": [{"expr": "ise_mnt_active_posture_field_coverage_ratio", "legendFormat": "{{field}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []}
    },
    {
      "id": 29,
      "type": "row",
      "title": "Persistent Collection Cache",
      "description": "Restart-persistent MnT detail caching and incremental Data Connect reconciliation.",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 57}
    },
    {
      "id": 30,
      "type": "stat",
      "title": "MnT Cached Active Details",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 58},
      "targets": [{"expr": "ise_mnt_active_posture_cache_entries", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}]
    },
    {
      "id": 31,
      "type": "stat",
      "title": "MnT Refresh Requests / Deferred",
      "description": "Actual detail calls and refreshes deferred by the production request budget.",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 58},
      "targets": [
        {"expr": "ise_mnt_active_posture_detail_requests", "instant": true, "legendFormat": "requested", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_mnt_active_posture_refresh_deferred", "instant": true, "legendFormat": "deferred", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Oldest Active Detail Cache Age",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 58},
      "targets": [{"expr": "ise_mnt_active_posture_cache_oldest_age_seconds", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 33,
      "type": "stat",
      "title": "RADIUS Incremental / Reconciliation Age",
      "description": "Mode 1 is a small new-event window; mode 0 is a full two-day reconciliation.",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 58},
      "targets": [
        {"expr": "ise_dataconnect_incremental_mode{domain=\"radius\"}", "instant": true, "legendFormat": "incremental mode", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataconnect_reconciliation_age_seconds{domain=\"radius\"}", "instant": true, "legendFormat": "reconciliation age", "refId": "B", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ]
    },
    {
      "id": 22,
      "type": "row",
      "title": "Data Connect Load Safety",
      "description": "Deployment-wide query pacing, runtime, result size, and adaptive duty-cycle protection.",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 62}
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Data Connect Statements per Minute",
      "description": "Fixed reporting-view labels only; arbitrary SQL is never exported.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 63},
      "targets": [{"expr": "60 * sum by (view, result) (rate(ise_dataconnect_queries_total[5m]))", "legendFormat": "{{view}} / {{result}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "qpm"}, "overrides": []}
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Data Connect Query p95 Duration",
      "description": "Statement latency by reporting view; compare with the 15-second hard timeout.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 63},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, view) (rate(ise_dataconnect_query_duration_seconds_bucket{result=\"success\"}[15m])))", "legendFormat": "{{view}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 25,
      "type": "table",
      "title": "Configured vs Effective Data Connect Cadence",
      "description": "Effective cadence grows automatically when query time would exceed the configured duty-cycle ceiling.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 71},
      "targets": [
        {"expr": "ise_dataset_interval_seconds{source=\"dataconnect\"}", "format": "table", "instant": true, "refId": "Configured", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataset_effective_interval_seconds{source=\"dataconnect\"}", "format": "table", "instant": true, "refId": "Effective", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}},
        {"expr": "ise_dataconnect_load_backoff_seconds", "format": "table", "instant": true, "refId": "Added backoff", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"showHeader": true}
    },
    {
      "id": 26,
      "type": "bargauge",
      "title": "Latest Data Connect Rows Returned",
      "description": "Client-side result size by fixed reporting view; grouped result caps protect exporter memory and metric cardinality.",
      "gridPos": {"h": 9, "w": 9, "x": 12, "y": 71},
      "targets": [{"expr": "ise_dataconnect_query_rows", "legendFormat": "{{view}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "id": 27,
      "type": "stat",
      "title": "Statement Pacing",
      "description": "Minimum idle time inserted between sequential Data Connect statements.",
      "gridPos": {"h": 9, "w": 3, "x": 21, "y": 71},
      "targets": [{"expr": "ise_dataconnect_query_pacing_seconds", "instant": true, "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 28,
      "type": "bargauge",
      "title": "Latest Global Query Cooldown",
      "description": "Quiet time imposed after each view query to keep aggregate Data Connect database duty cycle within the configured ceiling.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 80},
      "targets": [{"expr": "ise_dataconnect_query_cooldown_seconds", "legendFormat": "{{view}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    }
  ],
  "templating": {
    "list": [{
      "name": "DS_PROMETHEUS",
      "type": "datasource",
      "query": "prometheus",
      "label": "Prometheus",
      "current": {},
      "hide": 0
    }]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "annotations": {"list": []},
  "links": []
}
