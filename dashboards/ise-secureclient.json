{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "Secure Client posture outcomes parsed from the ISE 3.3 Patch 11 Data Connect posture assessment views.",
  "panels": [
    {
      "id": 90,
      "type": "stat",
      "title": "Dataset Availability",
      "description": "Authoritative Data Connect dataset health. DOWN is not a valid zero.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 91,
      "type": "stat",
      "title": "Dataset Collection Age",
      "description": "Seconds since the last successful snapshot replacement; thresholds are based on this dataset cadence.",
      "gridPos": {
        "h": 4,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"dataconnect_posture\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 600
              },
              {
                "color": "red",
                "value": 900
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Assessment-Group Compliance Share",
      "description": "Share of exported assessment groups in a compliant/passed state. Endpoints can occur in multiple OS, agent, policy, PSN, or status groups, so this is not a global distinct-endpoint compliance rate.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(100 * sum(ise_dataconnect_posture_endpoint_assessments{status=~\"(?i)compliant|passed\"}) / clamp_min(sum(ise_dataconnect_posture_endpoint_assessments{status=~\"(?i)compliant|passed|non.?compliant|failed\"}), 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed Assessment-Group Sum",
      "description": "Sum of failed/non-compliant grouped counts. An endpoint can occur in more than one group during the reporting window.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum(ise_dataconnect_posture_endpoint_assessments{status=~\"(?i)non.?compliant|failed\"}) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Assessment-Group Sum",
      "description": "Sum across status, OS, agent, policy, and PSN groups. This is not a global distinct endpoint count.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum(ise_dataconnect_posture_endpoint_assessments) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Posture Failure Codes",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "expr": "count(count by (message_code) (ise_dataconnect_posture_failures)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Posture Status Group Sums",
      "description": "Grouped assessment counts by status; repeated endpoints across other dimensions can be counted more than once.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (status) (ise_dataconnect_posture_endpoint_assessments)",
          "legendFormat": "{{status}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Secure Client / Posture Agent Versions",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(20, sum by (agent_version) (ise_dataconnect_posture_endpoint_assessments))",
          "legendFormat": "{{agent_version}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Endpoints by OS",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(20, sum by (os) (ise_dataconnect_posture_endpoint_assessments))",
          "legendFormat": "{{os}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Posture Policies: Passed vs Failed",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (policy, policy_status) (ise_dataconnect_posture_condition_assessments))",
          "legendFormat": "{{policy}} / {{policy_status}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Failed Posture Policies",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "topk(20, sum by (policy) (ise_dataconnect_posture_condition_assessments{policy_status=~\"(?i)fail(ed)?|non.?compliant\"}))",
          "legendFormat": "{{policy}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Failed Conditions",
      "gridPos": {
        "h": 11,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_posture_condition_assessments{condition_status=~\"(?i)fail(ed)?\"})",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Posture Failure Work Queue",
      "gridPos": {
        "h": 11,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_posture_failures)",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Assessments by PSN",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (psn, status) (ise_dataconnect_posture_endpoint_assessments))",
          "legendFormat": "{{psn}} / {{status}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "ise",
    "secure-client",
    "posture",
    "dataconnect"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-2d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "ISE Exporter / Secure Client & Posture",
  "uid": "ise-secureclient",
  "version": 1,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
