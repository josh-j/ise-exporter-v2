    {
      "id": 24,
      "type": "bargauge",
      "title": "Historical Policy/Condition Results (Data Connect)",
      "description": "This dedicated condition view can legitimately contain zero rows even when endpoint assessments exist.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 38
      },
