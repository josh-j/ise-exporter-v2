{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "schemaVersion": 39,
  "tags": ["ise", "cisco", "posture", "secure-client", "compliance"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "ISE Exporter / Secure Client & Posture",
  "uid": "ise-secureclient",
  "version": 3,
  "weekStart": "",
  "panels": [
    {
      "id": 1, "type": "row", "title": "Posture Compliance", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": []
    },
    {
      "id": 2, "type": "stat", "title": "Posture Compliance %",
      "description": "Compliant / (Compliant + NonCompliant) across active sessions, from the session postureStatus. Ignores NotApplicable and Pending. Note: if most sessions report postureStatus=NotApplicable, use the 'Posture Policy Results' section below (parsed from PostureReport) for the real per-check pass/fail.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "100 * sum(ise_session_posture_status{status=\"Compliant\"}) / clamp_min(sum(ise_session_posture_status{status=~\"Compliant|NonCompliant\"}), 1)", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 80 }, { "color": "green", "value": 95 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 3, "type": "stat", "title": "Failed Posture (Non-Compliant)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_posture_status{status=\"NonCompliant\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 4, "type": "stat", "title": "Pending Posture",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_posture_status{status=\"Pending\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "yellow", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 5, "type": "stat", "title": "Assessed Endpoints",
      "description": "Endpoints with a Compliant or NonCompliant verdict (i.e. a posture assessment actually ran).",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_posture_status{status=~\"Compliant|NonCompliant\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 6, "type": "bargauge", "title": "Posture Status Distribution",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (status) (ise_session_posture_status)", "legendFormat": "{{status}}", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Compliant" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "NonCompliant" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] }
        ]
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Posture Passed vs Failed Over Time",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_posture_status{status=\"Compliant\"})", "legendFormat": "Passed (Compliant)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_posture_status{status=\"NonCompliant\"})", "legendFormat": "Failed (NonCompliant)", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_posture_status{status=\"Pending\"})", "legendFormat": "Pending", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 25, "spanNulls": false, "showPoints": "never", "stacking": { "mode": "none", "group": "A" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Passed (Compliant)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Failed (NonCompliant)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8, "type": "bargauge", "title": "Failed Posture by Ops Owner",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (ops_owner) (ise_session_posture_status{status=\"NonCompliant\"})", "legendFormat": "{{ops_owner}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 17, "type": "bargauge", "title": "Pending Posture by Ops Owner",
      "description": "Endpoints stuck in posture Pending (assessment started but no Compliant/NonCompliant verdict yet), grouped by ops owner — where to chase agent/redirect problems.",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (ops_owner) (ise_session_posture_status{status=\"Pending\"})", "legendFormat": "{{ops_owner}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 9, "type": "table", "title": "Posture Passed / Failed by Ops Owner",
      "description": "Per ops owner, endpoints that passed (Compliant) vs failed (NonCompliant) overall posture. Excludes NotApplicable/Pending.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (ops_owner, status) (ise_session_posture_status{status=~\"Compliant|NonCompliant\"})", "format": "table", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "status" }, "properties": [
            { "id": "displayName", "value": "Result" },
            { "id": "mappings", "value": [{ "type": "value", "options": { "Compliant": { "text": "Passed", "color": "green", "index": 0 }, "NonCompliant": { "text": "Failed", "color": "red", "index": 1 } } }] },
            { "id": "custom.cellOptions", "value": { "type": "color-text" } }
          ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "endpoints", "desc": true }] },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "renameByName": { "ops_owner": "Ops Owner", "Value": "endpoints" } } }
      ]
    },
    {
      "id": 20, "type": "row", "title": "Posture Policy Results (per posture check)", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }, "panels": []
    },
    {
      "id": 21, "type": "table", "title": "Posture Policies — Passed vs Failed",
      "description": "Per posture policy (the individual checks: firewall, anti-malware, disk encryption, patch, ...), how many endpoints passed vs failed. Parsed from the PostureReport attribute — from pxGrid getEndpoints when it's publishing, otherwise from the MnT session other_attr_string fallback when getEndpoints returns 0. Empty only when no active session carries a PostureReport (e.g. no posture policy assigned).",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (policy, result) (ise_posture_policy_result)", "format": "table", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "result" }, "properties": [
            { "id": "displayName", "value": "Result" },
            { "id": "mappings", "value": [{ "type": "value", "options": { "Passed": { "color": "green", "index": 0 }, "Failed": { "color": "red", "index": 1 }, "Skipped": { "color": "text", "index": 2 }, "Pending": { "color": "yellow", "index": 3 } } }] },
            { "id": "custom.cellOptions", "value": { "type": "color-text" } }
          ] },
          { "matcher": { "id": "byName", "options": "policy" }, "properties": [{ "id": "displayName", "value": "Posture Policy" }] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "endpoints", "desc": true }] },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "renameByName": { "Value": "endpoints" } } }
      ]
    },
    {
      "id": 22, "type": "bargauge", "title": "Failed Posture Policies (top 15)",
      "description": "Posture policies with the most endpoints failing them — which specific checks (firewall, anti-malware, BitLocker, patch, ...) are driving non-compliance. From PostureReport.",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "topk(15, sum by (policy) (ise_posture_policy_result{result=\"Failed\"}))", "legendFormat": "{{policy}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 10, "type": "row", "title": "MDM / Device Trust (stream mode)", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }, "panels": []
    },
    {
      "id": 11, "type": "bargauge", "title": "MDM Registration",
      "description": "MDM-managed endpoints by enrollment state. Sourced from the pxGrid session object's mdm* fields — populated in stream mode only; empty under poll mode (MnT ActiveList doesn't carry MDM).",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (value) (ise_session_mdm_status{dimension=\"registered\"})", "legendFormat": "{{value}}", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "true" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "false" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 12, "type": "bargauge", "title": "MDM Compliance",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (value) (ise_session_mdm_status{dimension=\"compliant\"})", "legendFormat": "{{value}}", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "true" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "false" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 13, "type": "bargauge", "title": "MDM Risk Signals",
      "description": "Counts of MDM-managed endpoints tripping a device-risk flag.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_mdm_status{dimension=\"jailbroken\", value=\"true\"})", "legendFormat": "Jailbroken", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_mdm_status{dimension=\"disk_encrypted\", value=\"false\"})", "legendFormat": "Disk not encrypted", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_session_mdm_status{dimension=\"pin_locked\", value=\"false\"})", "legendFormat": "No PIN lock", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 14, "type": "row", "title": "Secure Client / Endpoint Agents", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 }, "panels": []
    },
    {
      "id": 15, "type": "bargauge", "title": "Secure Client / Posture Agent Version (top 15)",
      "description": "Endpoints by posture-agent / Secure Client version. From the getEndpoints PostureAgentVersion / SecureClientVersion attribute when publishing, otherwise from the MnT session other_attr_string fallback (SecureClientVersion / AnyConnectVersion / PostureAgentVersion) when getEndpoints returns 0. Empty only if no session or endpoint exposes a version attribute.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "topk(15, ise_endpoints_by_secureclient_version)", "legendFormat": "{{version}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 16, "type": "bargauge", "title": "Endpoints by OS (top 10)",
      "description": "MFC-derived operating system of profiled endpoints (reuses ise_endpoints_by_os). Requires COLLECT_PXGRID_ENDPOINTS=true.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "topk(10, ise_endpoints_by_os)", "legendFormat": "{{os}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    }
  ]
}
