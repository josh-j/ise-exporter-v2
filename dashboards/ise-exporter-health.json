{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "id": null,
  "uid": "ise-exporter-health",
  "title": "ISE Exporter Health",
  "tags": [
    "ise",
    "exporter",
    "health",
    "freshness",
    "data-quality"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "description": "Collection-plan health, source-event freshness, reporting-view coverage, and top-K truncation. A successful query is separated from genuinely current source data.",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Collection Health & Freshness",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unavailable",
      "description": "Enabled authoritative datasets whose latest collection attempt failed.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "count((ise_dataset_up{dataset=~\"$dataset\",source=~\"$source\"} == 0) and on(dataset,source) (ise_dataset_enabled{dataset=~\"$dataset\",source=~\"$source\"} == 1)) or on() (0 * (count(ise_dataset_up{dataset=~\"$dataset\",source=~\"$source\"}) > 0))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "links": [
            {
              "title": "Filter to this dataset",
              "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=${__field.labels.dataset}&var-source=${__field.labels.source}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Stale Datasets",
      "description": "Enabled datasets without a successful replacement inside twice their configured interval.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "count((ise_dataset_fresh{dataset=~\"$dataset\",source=~\"$source\"} == 0) and on(dataset,source) (ise_dataset_enabled{dataset=~\"$dataset\",source=~\"$source\"} == 1)) or on() (0 * (count(ise_dataset_up{dataset=~\"$dataset\",source=~\"$source\"}) > 0))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "links": [
            {
              "title": "Filter to this dataset",
              "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=${__field.labels.dataset}&var-source=${__field.labels.source}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Missing Expected View Updates",
      "description": "Periodic Data Connect rollup views with no row in the bounded recent window. Quiet event-driven views remain informational and do not raise this health count.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "(count((ise_dataconnect_view_has_recent_rows == 0) and on(view,domain) (ise_dataconnect_view_freshness_expected == 1)) and on() ((max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Truncation",
      "description": "Collector dimensional breakdowns where the configured top-K limit omits groups. Exact total metrics remain authoritative.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "((count(ise_dataconnect_radius_topk_truncated == 1) and on() ((max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)))) + ((ise_dataconnect_radius_active_groups_truncated and on() ((max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1)))) + ((count(ise_dataconnect_posture_topk_truncated == 1) and on() ((max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1)))) + ((count(ise_dataconnect_endpoint_topk_truncated == 1) and on() ((max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1)))) + ((count(ise_dataconnect_diagnostic_topk_truncated == 1) and on() ((max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)))) + ((count(ise_tacacs_topk_truncated == 1) and on() ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1)))) + ((ise_tacacs_internal_user_inventory_truncated and on() ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1))))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Unavailable Dataset Details",
      "description": "Every enabled unavailable or stale dataset, its collection source, bounded failure category, and operator-safe detail. A NONE row explicitly confirms that all enabled datasets are available and fresh.",
      "gridPos": {
        "h": 11,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(((ise_dataset_last_failure_detail_info{dataset=~\"$dataset\",source=~\"$source\"} or label_replace((ise_dataset_last_failure_info{dataset=~\"$dataset\",source=~\"$source\"} unless on(dataset,source) ise_dataset_last_failure_detail_info{dataset=~\"$dataset\",source=~\"$source\"}), \"detail\", \"Failure category: $1; inspect exporter journal\", \"reason\", \"(.+)\") or (label_replace(label_replace(ise_dataset_up{dataset=~\"$dataset\",source=~\"$source\"}, \"reason\", \"not_attempted\", \"dataset\", \".+\"), \"detail\", \"No collection attempt has completed or failed yet\", \"dataset\", \".+\") unless on(dataset,source) (ise_dataset_last_failure_info{dataset=~\"$dataset\",source=~\"$source\"} or ise_dataset_last_failure_detail_info{dataset=~\"$dataset\",source=~\"$source\"}))) and on(dataset,source) ((ise_dataset_up{dataset=~\"$dataset\",source=~\"$source\"} == 0) and on(dataset,source) (ise_dataset_enabled{dataset=~\"$dataset\",source=~\"$source\"} == 1))) or label_replace(label_replace(((ise_dataset_fresh{dataset=~\"$dataset\",source=~\"$source\"} == 0) and on(dataset,source) (ise_dataset_up{dataset=~\"$dataset\",source=~\"$source\"} == 1)) and on(dataset,source) (ise_dataset_enabled{dataset=~\"$dataset\",source=~\"$source\"} == 1), \"reason\", \"stale\", \"dataset\", \".+\"), \"detail\", \"Last successful collection is older than two configured intervals\", \"dataset\", \".+\") or label_replace(label_replace(label_replace(label_replace(absent(count(((ise_dataset_up{dataset=~\"$dataset\",source=~\"$source\"} == 0) or on(dataset,source) (ise_dataset_fresh{dataset=~\"$dataset\",source=~\"$source\"} == 0)) and on(dataset,source) (ise_dataset_enabled{dataset=~\"$dataset\",source=~\"$source\"} == 1))), \"dataset\", \"NONE\", \"\", \".*\"), \"source\", \"-\", \"\", \".*\"), \"reason\", \"healthy\", \"\", \".*\"), \"detail\", \"All enabled datasets are available and fresh\", \"\", \".*\"), \"dashboard_uid\", \"ise-overview\", \"dataset\", \".*\"), \"dashboard_uid\", \"ise-access-troubleshooting\", \"dataset\", \"dataconnect_radius.*|dataconnect_nad_health\"), \"dashboard_uid\", \"ise-psn-troubleshooting\", \"dataset\", \"dataconnect_performance\"), \"dashboard_uid\", \"ise-secureclient\", \"dataset\", \"dataconnect_posture|mnt_active_posture\"), \"dashboard_uid\", \"ise-tacacs\", \"dataset\", \"tacacs_.*\"), \"dashboard_uid\", \"ise-endpoints-devices\", \"dataset\", \"dataconnect_endpoints|devices\")",
          "format": "table",
          "instant": true,
          "refId": "Unavailable",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open responsible troubleshooting dashboard",
              "url": "/d/${__field.labels.dashboard_uid}/${__field.labels.dashboard_uid}?${__url_time_range}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true
            },
            "indexByName": {
              "dataset": 0,
              "source": 1,
              "reason": 2,
              "detail": 3
            },
            "renameByName": {
              "dataset": "Dataset",
              "source": "Source",
              "reason": "Failure category",
              "detail": "Why unavailable"
            }
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Dataset Collection Attempt and Success Age",
      "description": "Seconds since each enabled dataset was last attempted and last replaced successfully. Missing success series mean that dataset has never completed successfully since exporter state was reset.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "(time() - ise_dataset_last_attempt_timestamp{dataset=~\"$dataset\",source=~\"$source\"}) and on(dataset,source) (ise_dataset_enabled{dataset=~\"$dataset\",source=~\"$source\"} == 1)",
          "legendFormat": "{{dataset}} / {{source}} / attempt",
          "refId": "Attempt age",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "(time() - ise_dataset_last_success_timestamp{dataset=~\"$dataset\",source=~\"$source\"}) and on(dataset,source) (ise_dataset_enabled{dataset=~\"$dataset\",source=~\"$source\"} == 1)",
          "legendFormat": "{{dataset}} / {{source}} / success",
          "refId": "Success age",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "links": [
            {
              "title": "Filter to this dataset",
              "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=${__field.labels.dataset}&var-source=${__field.labels.source}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Data Connect Source-Event Freshness",
      "description": "Recent-row presence and newest recent event inside each view's configured bounded window. Each source probe returns at most one row; global emptiness, exact counts, and full-history scans are intentionally omitted to protect MnT.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "ise_dataconnect_view_has_recent_rows and on() ((max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "Has recent rows",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "(time() - (ise_dataconnect_view_newest_recent_event_timestamp > 0)) and on() ((max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "Newest recent event age",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "ise_dataconnect_view_freshness_expected and on() ((max(ise_dataset_up{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_freshness\",source=\"dataconnect\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "Health expectation",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "Source Data Quality",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Posture Coverage",
      "description": "Fraction of posture-applicable endpoints with a recent assessment in the bounded reporting window.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 29
      },
      "targets": [
        {
          "expr": "ise_dataconnect_posture_eligible_recent_assessment_ratio and on() ((max(ise_dataset_up{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_posture\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Unknown Endpoint Profiles",
      "description": "Data Connect reporting-snapshot endpoints whose profile is missing or unknown; some inventory attributes can synchronize with delay.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 29
      },
      "targets": [
        {
          "expr": "ise_dataconnect_endpoints_unknown_profile_total and on() ((max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Endpoints Stale 90d",
      "description": "Endpoint reporting-snapshot rows not updated during the last 90 days; this is not exact real-time endpoint state.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 29
      },
      "targets": [
        {
          "expr": "ise_dataconnect_endpoints_stale{age_days=\"90\"} and on() ((max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "MnT Detail Coverage",
      "description": "Successful detail lookups divided by selected active endpoints.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 29
      },
      "targets": [
        {
          "expr": "ise_mnt_active_posture_detail_coverage_ratio and on() ((max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "MnT Detail Truncated",
      "description": "1 means candidate active endpoints exceeded the configured detail-request bound.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 33
      },
      "targets": [
        {
          "expr": "ise_mnt_active_posture_detail_truncated and on() ((max(ise_dataset_up{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1) and (max(ise_dataset_fresh{dataset=\"mnt_active_posture\",source=\"mnt\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "COMPLETE",
                  "color": "green"
                },
                "1": {
                  "text": "TRUNCATED",
                  "color": "yellow"
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "NAD Inventory Export Coverage",
      "description": "Configured NADs selected for per-device series versus the exact ERS inventory total. Truncated=1 means inactive devices were omitted after active devices were prioritized.",
      "gridPos": {
        "h": 4,
        "w": 9,
        "x": 6,
        "y": 33
      },
      "targets": [
        {
          "expr": "ise_nad_inventory_selected and on() ((max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_up{dataset=\"devices\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"devices\",source=\"rest\"}) == 1))",
          "instant": true,
          "legendFormat": "selected",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "ise_nad_inventory_total and on() ((max(ise_dataset_up{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_nad_health\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_up{dataset=\"devices\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"devices\",source=\"rest\"}) == 1))",
          "instant": true,
          "legendFormat": "configured total",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
