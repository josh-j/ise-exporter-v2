{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "schemaVersion": 39,
  "tags": ["ise", "cisco", "profiler", "endpoints"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": { "text": "All", "value": ["$__all"] },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(ise_endpoints_by_profile_all, category)",
        "allValue": ".*",
        "hide": 0,
        "includeAll": true,
        "label": "Category",
        "multi": true,
        "name": "category",
        "options": [],
        "query": { "query": "label_values(ise_endpoints_by_profile_all, category)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "text": "20", "value": "20" },
        "hide": 0,
        "label": "Top N Profiles",
        "name": "topn",
        "options": [
          { "selected": false, "text": "10", "value": "10" },
          { "selected": true, "text": "20", "value": "20" },
          { "selected": false, "text": "30", "value": "30" },
          { "selected": false, "text": "50", "value": "50" },
          { "selected": false, "text": "100", "value": "100" }
        ],
        "query": "10,20,30,50,100",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "ISE Exporter / Endpoint Profiles",
  "uid": "ise-endpoint-profiles",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1, "type": "row", "title": "Profiler Overview", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": []
    },
    {
      "id": 2, "type": "stat", "title": "Endpoints Profiled (pxGrid)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_endpoints_pxgrid_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "id": 3, "type": "stat", "title": "Endpoints in Selected Categories",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_endpoints_by_profile_all{category=~\"$category\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 4, "type": "stat", "title": "Distinct Categories (populated)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "count(count by (category) (ise_endpoints_by_profile_all{category=~\"$category\"}))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 5, "type": "stat", "title": "Distinct Profiles (populated)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "count(ise_endpoints_by_profile_all{category=~\"$category\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 6, "type": "stat", "title": "Policies Defined (ISE catalog)",
      "description": "Total profiling policies in ISE's Policy > Profiling tree (pxGrid getProfiles) — includes policies with zero current endpoints, unlike the 'Distinct Profiles' stat.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_profiler_policies_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 7, "type": "stat", "title": "Hierarchy Cache Age",
      "description": "Seconds since the category/parent catalog was last refreshed from pxGrid (PXGRID_PROFILER_HIERARCHY_TTL, default 3600s). Climbing well past that TTL means the refresh is failing — check journalctl for 'pxGrid getProfiles' warnings.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_profiler_hierarchy_age_seconds", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3900 }, { "color": "red", "value": 7200 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "id": 8, "type": "row", "title": "Category & Profile Breakdown", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "panels": []
    },
    {
      "id": 9, "type": "piechart", "title": "Endpoints by Category",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_endpoints_by_profile_all{category=~\"$category\"}) by (category)", "legendFormat": "{{category}}", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"], "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 10, "type": "bargauge", "title": "Top $topn Profiles",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "topk($topn, ise_endpoints_by_profile_all{category=~\"$category\"})", "legendFormat": "{{profile}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 11, "type": "row", "title": "Profile Catalog", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }, "panels": []
    },
    {
      "id": 12, "type": "table", "title": "All Profiles (filter / sort)",
      "description": "One row per populated profiling policy, with its top-level category and immediate parent. Use the column filters and the Category variable to drill in.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_endpoints_by_profile_all{category=~\"$category\"}", "format": "table", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Endpoints" }] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Endpoints", "desc": true }] },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true } } }
      ]
    }
  ]
}
