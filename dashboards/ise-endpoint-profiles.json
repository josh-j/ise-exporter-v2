{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "Current endpoint profile distribution and recent profiling activity from ISE 3.3 Patch 11 Data Connect.",
  "panels": [
    {
      "id": 90,
      "type": "stat",
      "title": "Dataset Availability",
      "description": "Authoritative Data Connect dataset health. DOWN is not a valid zero.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 91,
      "type": "stat",
      "title": "Dataset Collection Age",
      "description": "Seconds since the last successful snapshot replacement; thresholds are based on this dataset cadence.",
      "gridPos": {
        "h": 4,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 7200
              },
              {
                "color": "red",
                "value": 10800
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Endpoints",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "ise_dataconnect_endpoints_total",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Populated Profiles",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "expr": "count(ise_dataconnect_endpoints_by_profile) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Profile Events",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "targets": [
        {
          "expr": "ise_dataconnect_profiled_endpoint_group_memberships_total or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_endpoints\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Top Profiles",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(25, ise_dataconnect_endpoints_by_profile)",
          "legendFormat": "{{profile}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "All Populated Profiles",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_endpoints_by_profile)",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Recent Profile Events",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "topk(30, ise_dataconnect_profile_events)",
          "legendFormat": "{{profile}} / {{source}} / {{action}} / {{identity_group}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    }
  ],
  "refresh": "15m",
  "schemaVersion": 39,
  "tags": [
    "ise",
    "endpoints",
    "profiling",
    "dataconnect"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-2d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "ISE Exporter / Endpoint Profiles",
  "uid": "ise-endpoint-profiles",
  "version": 1,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
