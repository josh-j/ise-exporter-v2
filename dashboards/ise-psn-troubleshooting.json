{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "schemaVersion": 39,
  "tags": ["ise", "cisco", "psn", "troubleshooting"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "Prometheus", "value": "prometheus" },
        "hide": 0, "label": "Prometheus", "name": "DS_PROMETHEUS",
        "options": [{ "selected": true, "text": "Prometheus", "value": "prometheus" }],
        "query": "prometheus", "refresh": 1, "regex": "", "type": "datasource"
      },
      {
        "allValue": ".*", "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(ise_radius_sessions_by_psn, psn)", "includeAll": true,
        "label": "PSN", "multi": true, "name": "psn", "options": [],
        "query": { "query": "label_values(ise_radius_sessions_by_psn, psn)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1, "regex": "", "sort": 1, "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "30s",
  "title": "ISE Exporter / PSN Metrics & Troubleshooting",
  "uid": "ise-psn-troubleshoot",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1, "type": "row", "title": "PSN Overview", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": []
    },
    {
      "id": 2, "type": "stat", "title": "ISE API", "description": "PAN API availability reported by the deployment collector.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_up", "refId": "A" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 3, "type": "stat", "title": "PSNs Reporting Sessions", "description": "Number of distinct PSN labels in MnT session data. Empty in pure streaming mode because pxGrid sessions do not identify the owning PSN.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "count(ise_radius_sessions_by_psn) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 4, "type": "stat", "title": "Sessions on Selected PSNs",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(ise_radius_sessions_by_psn{psn=~\"$psn\"}) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 5, "type": "stat", "title": "Auth Detail Cache Warmup",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_session_warmup_progress", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "textMode": "auto" }
    },
    {
      "id": 6, "type": "bargauge", "title": "Current Sessions by PSN", "description": "PSN names are reported by MnT session records; stale long-lived sessions may retain a pre-rename PSN label.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_radius_sessions_by_psn{psn=~\"$psn\"}", "legendFormat": "{{psn}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Sessions by PSN Over Time",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_radius_sessions_by_psn{psn=~\"$psn\"}", "legendFormat": "{{psn}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Session Change by PSN", "description": "Net change over the dashboard rate interval. A sharp loss on one PSN and gain on another can indicate failover or rebalance.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "delta(ise_radius_sessions_by_psn{psn=~\"$psn\"}[$__rate_interval])", "legendFormat": "{{psn}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 35, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9, "type": "row", "title": "Authentication Latency", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }, "panels": []
    },
    {
      "id": 10, "type": "timeseries", "title": "RADIUS Auth p95 by PSN", "description": "ISE TotalAuthenLatency for newly observed authentications. Includes authentication and authorization policy evaluation.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.95, sum by (le, psn, status) (ise_radius_auth_latency_by_psn_seconds_bucket{psn=~\"$psn\"}))", "legendFormat": "{{psn}} / {{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Client Latency p95 by PSN", "description": "ClientLatency reported in the ISE session attributes; zero is valid when the client contributes no measured delay.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.95, sum by (le, psn, status) (ise_radius_client_latency_seconds_bucket{psn=~\"$psn\"}))", "legendFormat": "{{psn}} / {{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12, "type": "timeseries", "title": "Slowest ISE Execution Steps (mean, top 15)", "description": "Cumulative mean since exporter start. StepLatency positions are joined to ISE execution_steps codes; use ISE Live Logs to decode a selected code in context.",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "topk(15, sum by (psn, step_code, status) (ise_radius_step_latency_seconds_sum{psn=~\"$psn\"}) / clamp_min(sum by (psn, step_code, status) (ise_radius_step_latency_seconds_count{psn=~\"$psn\"}), 1))", "legendFormat": "{{psn}} / step {{step_code}} / {{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 8, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 13, "type": "timeseries", "title": "Latency Sample Rate", "description": "New session details sampled per second. Empty latency panels with a zero sample rate mean there were no newly fetched authentications in the selected interval.",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (psn, status) (rate(ise_radius_auth_latency_by_psn_seconds_count{psn=~\"$psn\"}[$__rate_interval])) or vector(0)", "legendFormat": "{{psn}} / {{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 14, "type": "row", "title": "Deployment, Collectors & APIs", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }, "panels": []
    },
    {
      "id": 15, "type": "table", "title": "Deployment Node Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_deployment_status == 1", "format": "table", "instant": true, "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true } }, "overrides": [] },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false } },
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true } } }]
    },
    {
      "id": 16, "type": "bargauge", "title": "Collector Duration (last run)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sort_desc(ise_collector_duration_seconds)", "legendFormat": "{{collector}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 120 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "values": false } }
    },
    {
      "id": 17, "type": "table", "title": "Collector Health", "description": "Age since last success and consecutive failures. A stale authz or sessions collector explains missing PSN/latency data.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "time() - ise_last_successful_scrape_timestamp", "format": "table", "instant": true, "refId": "Age" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "ise_consecutive_failures", "format": "table", "instant": true, "refId": "Failures" }
      ],
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "color-background" }, "filterable": true }, "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 900 }] } }, "overrides": [] },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false } }
    },
    {
      "id": 18, "type": "text", "title": "Troubleshooting Path",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 41 },
      "options": { "mode": "markdown", "content": "1. **ISE API** must be UP and the `deployment`, `sessions`, and `authz` collectors must be fresh.\n2. Compare **Current Sessions by PSN** for imbalance or a sudden transfer. Old sessions can retain a pre-rename PSN label.\n3. Check **RADIUS Auth p95 by PSN**. If one PSN diverges, use **Slowest ISE Execution Steps** to isolate the policy-flow code.\n4. A zero **Latency Sample Rate** means no new session details were fetched; it is not a zero-latency measurement.\n5. Correlate step codes and failures with ISE Live Logs and the Auth Troubleshooting dashboard." }
    },
    {
      "id": 19, "type": "timeseries", "title": "API Request Rate",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (api, status) (rate(ise_api_requests_total[5m])) or vector(0)", "legendFormat": "{{api}} / {{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 20, "type": "timeseries", "title": "API Error Rate",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (api, error_type, http_code) (rate(ise_api_errors_total[5m])) or vector(0)", "legendFormat": "{{api}} / {{error_type}} / {{http_code}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "showPoints": "never", "spanNulls": false }, "color": { "mode": "continuous-RdYlGr" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 21, "type": "timeseries", "title": "Collector Scrape Error Rate",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (collector, error_type) (rate(ise_scrape_errors_total[5m])) or vector(0)", "legendFormat": "{{collector}} / {{error_type}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "showPoints": "never", "spanNulls": false } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    }
  ]
}
