{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "ISE node capacity, RADIUS workload, latency, and diagnostics from Data Connect, with REST deployment and exporter health.",
  "panels": [
    {
      "id": 90,
      "type": "stat",
      "title": "Dataset Availability",
      "description": "Authoritative Data Connect dataset health. DOWN is not a valid zero.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 91,
      "type": "stat",
      "title": "Dataset Collection Age",
      "description": "Seconds since the last successful snapshot replacement; thresholds are based on this dataset cadence.",
      "gridPos": {
        "h": 4,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"dataconnect_performance\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5400
              },
              {
                "color": "red",
                "value": 7200
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "ISE API",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "ise_up",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reporting Nodes",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "targets": [
        {
          "expr": "(count(ise_dataconnect_psn_radius_requests_per_hour) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RADIUS Requests / Hour",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "(sum(ise_dataconnect_psn_radius_requests_per_hour) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Diagnostic Events",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "expr": "(sum(ise_dataconnect_diagnostic_events_total) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "RADIUS Requests per Hour by Node",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_psn_radius_requests_per_hour) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Average RADIUS Latency",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_psn_average_latency_seconds) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Average TPS",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_psn_average_tps) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Node Load",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ise_dataconnect_psn_load_percent and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{node}} / {{stat}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CPU Utilization",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ise_dataconnect_node_cpu_utilization_percent and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Memory Utilization",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ise_dataconnect_node_memory_utilization_percent and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{node}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Disk Utilization",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_node_disk_utilization_percent) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{node}} / {{partition}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Reporting Logs, Noise, and Suppression",
      "description": "ISE reporting-pipeline counters exposed through Data Connect.",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 24
      },
      "targets": [
        {
          "expr": "ise_dataconnect_psn_mnt_logs_per_hour and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "logs / {{node}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "ise_dataconnect_psn_noise_per_hour and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "noise / {{node}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "ise_dataconnect_psn_suppression_per_hour and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "suppressed / {{node}}",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "table",
      "title": "Diagnostic Work Queue",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_diagnostic_events) and on() (max(ise_dataset_up{dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 14,
      "type": "table",
      "title": "Deployment Node Status",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "targets": [
        {
          "expr": "(ise_deployment_status == 1) and on() (max(ise_dataset_up{dataset=\"deployment\",source=\"rest\"}) == 1)",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "Collector Health",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 44
      },
      "targets": [
        {
          "expr": "time() - ise_last_successful_scrape_timestamp",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "ise_consecutive_failures",
          "format": "table",
          "instant": true,
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "ise",
    "psn",
    "dataconnect",
    "troubleshooting"
  ],
  "templating": {
