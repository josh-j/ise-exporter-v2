{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "ISE node capacity, RADIUS workload, latency, and diagnostics from Data Connect, with REST deployment and exporter health.",
  "panels": [
    {
      "id": 90,
      "type": "stat",
      "title": "Dataset Availability",
      "description": "Authoritative Data Connect dataset health. DOWN is not a valid zero.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "links": [
            {
              "title": "Inspect PSN dataset health",
              "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=dataconnect_performance&var-source=dataconnect",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 91,
      "type": "stat",
      "title": "Dataset Collection Age",
      "description": "Seconds since the last successful PSN snapshot replacement. Yellow after one five-minute interval plus grace; red after two intervals.",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 450
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          },
          "links": [
            {
              "title": "Inspect PSN dataset health",
              "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=dataconnect_performance&var-source=dataconnect",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 92,
      "type": "stat",
      "title": "Missing PSN Schema Columns",
      "description": "Known optional PSN reporting columns absent from the production Data Connect schema. A non-zero value explains metric-specific gaps while the dataset remains available.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(1 - ise_dataconnect_schema_column_available{instance=~\"$deployment\",view=~\"KEY_PERFORMANCE_METRICS|SYSTEM_SUMMARY|AAA_DIAGNOSTICS_VIEW|SYSTEM_DIAGNOSTICS_VIEW\",column!=\"TIMESTAMP_TIMEZONE\",requirement=\"optional\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "links": [
            {
              "title": "Inspect missing schema columns",
              "url": "/d/ise-exporter-health/ise-exporter-health?${__url_time_range}&var-dataset=dataconnect_performance&var-source=dataconnect",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "ISE API",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "ise_up{instance=~\"$deployment\"}",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reporting Nodes",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "targets": [
        {
          "expr": "(count(ise_dataconnect_psn_radius_requests_per_hour{instance=~\"$deployment\",node=~\"$psn\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RADIUS Requests / Hour",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "(sum(ise_dataconnect_psn_radius_requests_per_hour{instance=~\"$deployment\",node=~\"$psn\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Diagnostic Events",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "expr": "(sum(ise_dataconnect_diagnostic_events{instance=~\"$deployment\",node=~\"$psn\"}) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_performance\",source=\"dataconnect\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 16,
      "type": "bargauge",
      "title": "Active Sessions per PSN",
      "description": "Likely-active sessions reconstructed from each session ID's latest accounting record. Values depend on NAD accounting quality and the bounded active-session group export.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (psn) (ise_dataconnect_radius_active_sessions{instance=~\"$deployment\",psn=~\"$psn\"})) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "legendFormat": "{{psn}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "links": [
            {
              "title": "Investigate this PSN in Access",
              "url": "/d/ise-access-troubleshooting/ise-access-troubleshooting?${__url_time_range}&var-psn=${__field.labels.psn}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showUnfilled": true
      }
    },
    {
      "id": 17,
      "type": "bargauge",
      "title": "Session Delta per PSN",
      "description": "Accounting starts minus stops per PSN in the bounded Data Connect reporting window. Positive values mean more starts than stops; values depend on NAD accounting quality and bounded group coverage.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (psn) (ise_dataconnect_radius_accounting_events{instance=~\"$deployment\",psn=~\"$psn\",event_type=~\"(?i).*start.*\"} or (ise_dataconnect_radius_accounting_events{instance=~\"$deployment\",psn=~\"$psn\",event_type=~\"(?i).*stop.*\"} * -1))) and on() ((max(ise_dataset_up{instance=~\"$deployment\",dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{instance=~\"$deployment\",dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "legendFormat": "{{psn}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "links": [
            {
              "title": "Investigate this PSN in Access",
              "url": "/d/ise-access-troubleshooting/ise-access-troubleshooting?${__url_time_range}&var-psn=${__field.labels.psn}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showUnfilled": true
      }
    },
