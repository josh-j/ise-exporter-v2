    {
      "id": 1,
      "type": "row",
      "title": "Device Administration Account Health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Internal Accounts",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "(ise_tacacs_internal_users_total and on() ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Suspected Unused",
      "description": "Enabled internal accounts with neither an object change nor exporter-observed TACACS activity inside the configured review period. Only three high-water timestamps per configured internal account are retained; raw MnT history is never copied.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "targets": [
        {
          "expr": "(sum(ise_tacacs_suspected_unused_internal_user{username=~\"$username\"} unless on(username) max by (username) (ise_tacacs_account_last_seen_timestamp{username=~\"$username\"} > time() - scalar(ise_tacacs_unused_account_review_seconds))) and on() ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1)) and on() ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1)) and on() ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Focus this username",
              "url": "/d/ise-tacacs/ise-tacacs?${__url_time_range}&var-username=${__field.labels.username}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Data Connect Activity Up",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Recent TACACS Events",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "targets": [
        {
          "expr": "(sum(ise_tacacs_events_total) and on() ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1))) or on() (0 * ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1)))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Internal Account Inventory",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "ise_tacacs_internal_user_info{username=~\"$username\"} and on() ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Focus this username",
              "url": "/d/ise-tacacs/ise-tacacs?${__url_time_range}&var-username=${__field.labels.username}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Account Hygiene Review Queue",
      "description": "Unused-account candidates require current REST inventory and Data Connect activity collection. Activity retention is bounded to three timestamps per configured internal account, independent of MnT database size.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "expr": "(ise_tacacs_suspected_unused_internal_user{username=~\"$username\"} unless on(username) max by (username) (ise_tacacs_account_last_seen_timestamp{username=~\"$username\"} > time() - scalar(ise_tacacs_unused_account_review_seconds))) and on() ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1)) and on() ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "ise_tacacs_internal_user_hygiene_risk{username=~\"$username\"} and on() ((max(ise_dataset_up{dataset=\"tacacs_config\",source=\"rest\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_config\",source=\"rest\"}) == 1))",
          "format": "table",
          "instant": true,
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Focus this username",
              "url": "/d/ise-tacacs/ise-tacacs?${__url_time_range}&var-username=${__field.labels.username}",
              "targetBlank": false
            }
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Authentication by Account and Result",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (username, status, device) (ise_tacacs_account_authentication_events{username=~\"$username\"})) and on() ((max(ise_dataset_up{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"tacacs_activity\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "{{username}} / {{status}} / {{device}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "links": [
            {
              "title": "Focus this username",
              "url": "/d/ise-tacacs/ise-tacacs?${__url_time_range}&var-username=${__field.labels.username}",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*[Pp]ass.*|.*[Ss]uccess.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*[Ff]ail.*|.*[Ee]rror.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showUnfilled": true
      }
    },
