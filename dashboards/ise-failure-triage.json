          "expr": "(\n  sum(ise_session_status_endpoints{status=\"failed\", ops_owner=~\"$ops_owner\", location=~\"$location\"})\n  /\n  sum(ise_session_status_endpoints{ops_owner=~\"$ops_owner\", location=~\"$location\"})\n) * 100",
