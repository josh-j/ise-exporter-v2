{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "RADIUS failure work queue from stable Data Connect dimensions. Counts cover the bounded ISE reporting view, not unique currently connected endpoints.",
  "panels": [
    {
      "id": 90,
      "type": "stat",
      "title": "Dataset Availability",
      "description": "Authoritative Data Connect dataset health. DOWN is not a valid zero.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 91,
      "type": "stat",
      "title": "Dataset Collection Age",
      "description": "Seconds since the last successful snapshot replacement; thresholds are based on this dataset cadence.",
      "gridPos": {
        "h": 4,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"dataconnect_radius\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 129600
              },
              {
                "color": "red",
                "value": 172800
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Failed Authentication Events",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "(ise_dataconnect_radius_failure_events_total and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failure Rate",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "((100 * ise_dataconnect_radius_failure_events_total / clamp_min(ise_dataconnect_radius_authentication_events_total, 1)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "NADs Producing Errors",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "targets": [
        {
          "expr": "(count(count by (nad) (ise_dataconnect_radius_errors)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Failure Events by Status",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (status) (ise_dataconnect_radius_authentication_events{status=~\"(?i)fail(ed)?|reject(ed)?\"}) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{status}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Top Error Codes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(20, sum by (message_code) (ise_dataconnect_radius_errors)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{message_code}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Failing NADs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "topk(20, sum by (nad) (ise_dataconnect_radius_authentication_events{status=~\"(?i)fail(ed)?|reject(ed)?\"})) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{nad}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Auth Methods at Failing NADs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (nad, authentication_method) (ise_dataconnect_radius_authentication_events{status=~\"(?i)fail(ed)?|reject(ed)?\"})) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{nad}} / {{authentication_method}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Errors by PSN",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (psn, message_code) (ise_dataconnect_radius_errors)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{psn}} / {{message_code}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Certificate and PKI Errors",
      "description": "Common certificate-related ISE message codes; tune this expression when Cisco adds codes to the targeted release.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "(sum(ise_dataconnect_radius_errors{message_code=~\"12300|12321|12500|12501|12511|12625|22056\"}) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Failure Classes",
      "description": "Failed authentications grouped into bounded reason classes from Cisco's aggregate RADIUS summary view.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (failure_class) (ise_dataconnect_radius_failure_events)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "instant": true,
          "legendFormat": "{{failure_class}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Failed Authorization Profiles",
      "description": "Authorization profiles associated with failed authentications in the bounded aggregate reporting window.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 32
      },
      "targets": [
        {
          "expr": "topk(20, sum by (authorization_profile) (ise_dataconnect_radius_failure_events)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "instant": true,
          "legendFormat": "{{authorization_profile}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "Failure Locations",
      "description": "Network-device locations associated with failed authentications in the bounded aggregate reporting window.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 32
      },
      "targets": [
        {
          "expr": "topk(20, sum by (location) (ise_dataconnect_radius_failure_events)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "instant": true,
          "legendFormat": "{{location}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "RADIUS Failure Work Queue",
      "description": "One row per failed-authentication combination of NAD, method, protocol, authorization policy, and PSN. Error-code panels above remain sourced from the separate RADIUS errors view.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_radius_authentication_events{status=~\"(?i)fail(ed)?|reject(ed)?\"}) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "format": "table",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "ise",
    "radius",
    "dataconnect",
    "failures"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-2d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "C2C RADIUS Failure Triage",
  "uid": "ise-failure-triage",
  "version": 1,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
