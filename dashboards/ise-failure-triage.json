    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Top failure codes by affected endpoint count. Common codes: 11036 (MAB unknown MAC), 11512 (EAP-NAK, supplicant negotiating wrong EAP), 12300 (no client cert offered), 12500/12501 (client cert verify failed/not trusted), 12511 (cert revoked), 12625 (EAP-TLS timeout), 22037/22040 (user not found / bad password), 22056 (subject DN missing), 15039 (AuthZ rule denied).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-BlPu"
          },
          "mappings": [
            {
              "options": {
                "5400": {
                  "index": 0,
                  "text": "5400 \u2014 Auth failed (generic)"
                },
                "5411": {
                  "index": 1,
                  "text": "5411 \u2014 Supplicant stopped responding"
                },
                "5434": {
                  "index": 2,
                  "text": "5434 \u2014 Repeated failed auths"
                },
                "5440": {
                  "index": 3,
                  "text": "5440 \u2014 EAP session abandoned"
                },
                "11036": {
                  "index": 4,
                  "text": "11036 \u2014 MAB: unknown MAC"
                },
                "11038": {
                  "index": 5,
                  "text": "11038 \u2014 RADIUS req invalid"
                },
                "11504": {
                  "index": 6,
                  "text": "11504 \u2014 Bad Message-Authenticator"
                },
                "11507": {
                  "index": 7,
                  "text": "11507 \u2014 Unknown EAP method"
                },
                "11512": {
                  "index": 8,
                  "text": "11512 \u2014 EAP-NAK unsupported"
                },
                "12300": {
                  "index": 9,
                  "text": "12300 \u2014 No client cert offered"
                },
                "12321": {
                  "index": 10,
                  "text": "12321 \u2014 PEAP TLS handshake"
                },
                "12500": {
                  "index": 11,
                  "text": "12500 \u2014 Client cert verify fail"
                },
                "12501": {
                  "index": 12,
                  "text": "12501 \u2014 Client cert not trusted"
                },
                "12511": {
                  "index": 13,
                  "text": "12511 \u2014 Client cert revoked"
                },
                "12625": {
                  "index": 14,
                  "text": "12625 \u2014 EAP-TLS timeout"
                },
                "15039": {
                  "index": 15,
                  "text": "15039 \u2014 AuthZ rule denied"
                },
                "22037": {
                  "index": 16,
                  "text": "22037 \u2014 User not found"
                },
                "22040": {
                  "index": 17,
                  "text": "22040 \u2014 Wrong password"
                },
                "22056": {
                  "index": 18,
                  "text": "22056 \u2014 Subject DN not found"
                },
                "24209": {
                  "index": 19,
                  "text": "24209 \u2014 MAB without 802.1X"
                },
                "24211": {
                  "index": 20,
                  "text": "24211 \u2014 MAB succeeded"
                }
              },
              "type": "value"
            }
          ],
