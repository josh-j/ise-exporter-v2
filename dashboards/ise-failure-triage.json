      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Total unique endpoints currently failing authentication in scope. Each contributes once per failure reason; one device with multiple distinct failures counts once per reason.",
