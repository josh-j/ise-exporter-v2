{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "description": "Endpoint reporting from Data Connect plus authoritative network-device inventory from REST/OpenAPI.",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Endpoints",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "ise_dataconnect_endpoints_total",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Network Devices",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "ise_network_devices_total",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Populated Profiles",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(ise_dataconnect_endpoints_by_profile) or vector(0)",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Identity Groups",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(ise_dataconnect_endpoints_by_identity_group) or vector(0)",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Endpoints by Profile",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "topk(20, ise_dataconnect_endpoints_by_profile)",
          "legendFormat": "{{profile}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Endpoints by Identity Group",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "topk(20, ise_dataconnect_endpoints_by_identity_group)",
          "legendFormat": "{{identity_group}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Posture Applicability",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "ise_dataconnect_endpoints_by_posture_applicable",
          "legendFormat": "{{applicable}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Profile Events by Source and Action",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 13
      },
      "targets": [
        {
          "expr": "topk(25, sum by (profile, source, action) (ise_dataconnect_profile_events))",
          "legendFormat": "{{profile}} / {{source}} / {{action}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Devices by Location",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "expr": "ise_network_devices_by_location",
          "legendFormat": "{{location}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Devices by Ops Owner",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 21
      },
      "targets": [
        {
          "expr": "ise_network_devices_by_ops_owner",
          "legendFormat": "{{ops_owner}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Devices by Type",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 21
      },
      "targets": [
        {
          "expr": "ise_network_devices_by_type",
          "legendFormat": "{{device_type}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    }
  ],
  "refresh": "15m",
  "schemaVersion": 39,
  "tags": [
    "ise",
    "endpoints",
    "dataconnect",
    "rest"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-2d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "ISE Exporter / Endpoints & Devices",
  "uid": "ise-endpoints-devices",
  "version": 1,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
