      "targets": [
        {
          "expr": "sort_desc(sum by (psn, status) (ise_dataconnect_radius_authentication_events)) and on() ((max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1) and (max(ise_dataset_fresh{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "legendFormat": "{{psn}} / {{status}}",
          "refId": "A",
          "datasource": {
