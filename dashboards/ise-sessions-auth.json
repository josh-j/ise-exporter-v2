{
  "annotations": {
    "list": []
  },
  "description": "RADIUS authentication and accounting reporting from Cisco ISE 3.3 Patch 11 Data Connect. Likely active sessions are reconstructed from each accounting session ID's latest record.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 90,
      "type": "stat",
      "title": "Dataset Availability",
      "description": "Authoritative Data Connect dataset health. DOWN is not a valid zero.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "Reporting",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "Active sessions",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 91,
      "type": "stat",
      "title": "Dataset Collection Age",
      "description": "Seconds since the last successful snapshot replacement; thresholds are based on this dataset cadence.",
      "gridPos": {
        "h": 4,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"dataconnect_radius\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "Reporting",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "expr": "time() - max(ise_dataset_last_success_timestamp{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"})",
          "instant": true,
          "refId": "Active sessions",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 129600
              },
              {
                "color": "red",
                "value": 172800
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "Active sessions"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 2700
                    },
                    {
                      "color": "red",
                      "value": 3600
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 1,
      "type": "row",
      "title": "RADIUS Reporting Window",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Authentication Events",
      "description": "Authentication events in the bounded Data Connect view.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "(ise_dataconnect_radius_authentication_events_total and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Likely Active Sessions",
      "description": "Latest accounting record per session ID is Start or Interim, not Stop. Depends on NAD accounting quality.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "targets": [
        {
          "expr": "(ise_dataconnect_radius_active_sessions_total and on() (max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius_active\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Accounting Starts",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "(ise_dataconnect_radius_accounting_event_type_total{event_type=\"start\"} and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Accounting Stops",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "targets": [
        {
          "expr": "(ise_dataconnect_radius_accounting_event_type_total{event_type=\"stop\"} and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)) or on() (0 * (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1))",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Authentication Events by Status",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum by (status) (ise_dataconnect_radius_authentication_events) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{status}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Authentication Methods",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (authentication_method) (ise_dataconnect_radius_authentication_events)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{authentication_method}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Authentication by NAD",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "expr": "topk(20, sum by (nad) (ise_dataconnect_radius_authentication_events)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{nad}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Accounting Events by NAD",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "targets": [
        {
          "expr": "topk(20, sum by (nad) (ise_dataconnect_radius_accounting_events)) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{nad}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "RADIUS Response Time by Statistic",
      "description": "Data Connect response-time aggregates; stat identifies average, maximum, or other view-provided aggregation.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ise_dataconnect_radius_response_time_seconds and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{stat}} / {{status}} / {{nad}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Accounting Session Duration",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sort_desc(ise_dataconnect_radius_accounting_session_seconds) and on() (max(ise_dataset_up{dataset=\"dataconnect_radius\",source=\"dataconnect\"}) == 1)",
          "legendFormat": "{{stat}} / {{nad}} / {{psn}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "ise",
    "radius",
    "dataconnect"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-2d",
    "to": "now"
  },
  "timezone": "browser",
  "title": "ISE Exporter / RADIUS Authentication & Accounting",
  "uid": "ise-sessions-auth",
  "version": 1,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ]
}
