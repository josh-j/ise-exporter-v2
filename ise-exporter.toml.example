# Cisco ISE exporter configuration
#
# Copy to /etc/ise-exporter/config.toml, or set:
#   ISE_EXPORTER_CONFIG=/path/to/config.toml
#
# For secret injection, only the ISE_PASS and ISE_DATACONNECT_PASSWORD
# environment variables override values in this file.
#
# Durations are in seconds and request pacing is in milliseconds unless the
# setting name says otherwise. State/guard paths must be writable by the service;
# CA bundles only need to be readable.

[exporter]
# Python log level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
log_level = "INFO"
# Prometheus listens on all interfaces at this port.
port = 9618
# Persistent snapshots and collection timestamps. Keeping this file makes
# dashboards useful soon after a restart instead of waiting for every poll.
state_db = "/var/lib/ise-exporter/state.sqlite3"
# Default polling tiers used by collectors without a dedicated interval below.
scrape_interval_seconds = 60
medium_interval_seconds = 300
slow_interval_seconds = 21600
# Minimum spacing between cold-start collector attempts. This avoids a burst of
# requests when the service starts; set lower only if ISE can absorb the burst.
startup_rate_limit_seconds = 5

[ise]
# PAN address for ERS and OpenAPI. Use a bare hostname or IPv4 address, not a URL.
host = "pan1.example.com"
# MnT address for active-session posture lookups. It may be the same as host.
mnt_host = "mnt1.example.com"
# Read-only ERS/OpenAPI account.
user = "ers.readonly"
# Prefer the ISE_PASS environment override in production secret managers.
password = "changeme"
# ERS uses 9060 on the supported ISE deployment; OpenAPI uses normal HTTPS.
ers_port = 9060
# Hard timeout for each REST or MnT request.
request_timeout_seconds = 30
# Stop retrying after repeated authentication failures, preventing account lockout.
auth_failure_backoff_seconds = 900
auth_failure_threshold = 3
# Persistent authentication backoff shared by the exporter and authorized CLI.
auth_guard_file = "/var/lib/ise-exporter/shared/rest-auth.guard"

[ise.rest_tls]
# Production should verify ISE certificates using the issuing CA bundle below.
verify = true
ca_bundle = "/etc/ise-exporter/certs/ise-ca.cer"

[ise.mnt_tls]
# MnT can use a different certificate chain. If this section is omitted, the
# REST TLS settings are inherited.
verify = true
ca_bundle = "/etc/ise-exporter/certs/ise-ca.cer"

[collectors]
# Expensive or optional collection families can be disabled independently.
# Core deployment health and Data Connect schema discovery remain available.
device_details = true
certificates = true
licensing = true
backup_status = true
patches = true
tacacs = true
mnt_active_posture = true

[devices]
# Retain ERS device detail in the local cache for 30 days. Inventory is still
# refreshed, but unchanged devices do not need repeated detail requests.
cache_ttl_seconds = 2592000 # 30 days
# Per-pass budget of NAD detail requests, spaced by detail_request_interval_ms to
# protect the PAN. The detail refresh runs on its own background worker (off the
# synchronous REST lane). 0 (default) auto-sizes the budget to the inventory that
# still needs a refresh, bounded by a hard 10000-per-pass ceiling, so a large fleet
# fills detail coverage in one paced background pass and then only refreshes new or
# stale NADs. Coverage counts any cached NAD, so it climbs to 100% and holds. Set a
# positive value to cap requests per pass explicitly.
detail_max_requests = 0
detail_request_interval_ms = 250

[mnt_active_posture]
# Current active-session posture is a bounded MnT snapshot, not historical data.
interval_seconds = 300 # 5 minutes
# Refuse ActiveList responses above this size rather than parsing an unsafe payload.
max_active_list_sessions = 10000
# Retain at most this many sessions from a valid ActiveList response.
max_sessions = 1000
# Parallel detail lookups. Increasing this raises load on the MnT node.
workers = 2
# Keep the hourly request ceiling near the former 15-minute profile while
# refreshing the aggregate snapshot every five minutes.
max_requests_per_cycle = 80
# Reuse unchanged session details for up to one hour.
refresh_ttl_seconds = 3600 # 1 hour
request_interval_ms = 500

[tacacs]
# Report internal Device Administration accounts unused for at least this many days.
unused_account_days = 180

[tacacs.users]
# Bound the number of internal users considered and their ERS detail lookups.
max = 1000
detail_max_requests = 100
# User detail changes slowly, so cache it for seven days.
detail_ttl_seconds = 604800 # 7 days
detail_request_interval_ms = 250

[tacacs.policies]
# Bound policy-set discovery and rule detail refreshes.
max_sets = 100
rule_refresh_max = 10
# Policy rules are cached for seven days unless selected for a bounded refresh.
rule_ttl_seconds = 604800 # 7 days
rule_request_interval_ms = 250

[dataconnect]
# MnT Data Connect is an Oracle-compatible, read-only reporting interface.
# Use a bare hostname or IPv4 address that matches the certificate when TLS is on.
host = "mnt1.example.com"
port = 2484
service = "cpm10"
# Cisco ISE uses the fixed dataconnect username.
user = "dataconnect"
# Prefer ISE_DATACONNECT_PASSWORD from a production secret manager.
password = "changeme"
verify_tls = true
ca_bundle = "/etc/ise-exporter/certs/ise-ca.cer"
# Hard timeout for a reporting statement. The runtime caps this at 15 seconds.
query_timeout_seconds = 15
# Maximum distinct groups retained by bounded aggregate queries.
max_groups = 1000
# Never begin Data Connect statements faster than this minimum interval.
min_query_interval_ms = 5000
# Adaptive shared pacing keeps measured database work below this percentage of
# database time. After each statement the exporter waits duration*(100/duty - 1)
# on ONE global gate shared by every reporting dataset, so a lower value throttles
# freshness across the board: at 0.1 a single 5s query pauses all datasets ~83 min;
# at 1.0 (default) ~8 min; at 2.0 ~4 min. Recommended band is 0.1-2.0; the exporter
# logs an advisory and sets ise_dataconnect_duty_cycle_advisory when outside it.
# Large deployments (tens of thousands of endpoints) tune toward 2.0 so operational
# panels approach their configured cadence. Note: multiple exporter instances share
# one budget. (1.0 means one percent of database time, not ten percent.)
max_duty_cycle_percent = 1.0
# Historical event queries inspect at most this many recent hours.
event_window_hours = 6
# Opt-in: accumulate RADIUS accounting events as monotonic counters by tailing only
# new rows since a persisted id cursor, so Prometheus computes rate()/increase() over
# any window instead of the exporter re-summing a fixed window each cycle. Off by
# default until the id-sequence model is validated on a multi-PSN deployment; see
# docs/incremental-tailing-plan.md. Publishes ise_dataconnect_radius_accounting_tail_total.
accounting_event_counters = false
# Opt-in: the same incremental id-tail applied to posture assessments. Accumulates
# monotonic status x psn counters (ise_dataconnect_posture_assessment_tail_total) so
# Prometheus derives the assessment throughput/rate over any window. This is the
# assessment-event rate, distinct from endpoint_fleet (per-endpoint coverage/compliance).
# Shares tail_settle_seconds / tail_max_backfill_hours below. Off by default.
posture_event_counters = false
# Opt-in: the same incremental id-tail applied to RADIUS authentications. Accumulates
# monotonic result x psn counters (ise_dataconnect_radius_authentication_tail_total,
# result=passed/failed) so Prometheus derives the auth pass/fail rate over any window.
# RADIUS_AUTHENTICATIONS carries the same global ID as RADIUS_ACCOUNTING. Shares
# tail_settle_seconds / tail_max_backfill_hours below. Off by default; the collector
# self-skips if the live schema shows the view has no ID column.
authentication_event_counters = false
# Opt-in: the same incremental id-tail applied to RADIUS errors. Accumulates monotonic
# message_code x psn counters (ise_dataconnect_radius_error_tail_total) so Prometheus
# derives the RADIUS error rate over any window. Complements the windowed top-K
# ise_dataconnect_radius_errors gauge. RADIUS_ERRORS_VIEW carries the same global ID.
# Shares tail_settle_seconds / tail_max_backfill_hours below. Off by default; the
# collector self-skips if the live schema shows the view has no ID column.
error_event_counters = false
# Do not advance the tail cursor past rows added within this many seconds, so rows
# whose (lower) id is still committing are not skipped. A few multiples of MnT
# ingestion lag. Effectively-once for a rate metric, not a ledger guarantee.
tail_settle_seconds = 30
# Cost backstop: a cold start or a cursor left far behind (long downtime) backfills
# at most this many hours of accounting rather than scanning the whole view.
tail_max_backfill_hours = 6
# These files coordinate pacing and authentication backoff across the service
# and authorized CLI users. Keep them on local storage in a shared writable dir.
shared_pacing_file = "/var/lib/ise-exporter/shared/dataconnect.pacing"
auth_guard_file = "/var/lib/ise-exporter/shared/dataconnect-auth.guard"

[dataconnect.intervals]
# Schema validation runs first and gates all reporting datasets. Cached snapshots
# are restored after validation so restarts become useful without re-querying all data.
schema_seconds = 86400 # 1 day
# RADIUS troubleshooting aggregates refresh every 30 minutes. The single
# active-session statement also emits start-minus-stop delta every five minutes.
radius_seconds = 1800 # 30 minutes
# Values above 3600 are normalized to the hard one-hour stale window.
radius_active_seconds = 300 # 5 minutes
# PSN CPU, memory, latency, diagnostics, and throughput troubleshooting.
performance_seconds = 300 # 5 minutes
# Incremental accounting-counter tail cadence (only used when
# dataconnect.accounting_event_counters is enabled). The tail is cheap, so this can
# be short for fresh rates without re-scanning a window.
accounting_counters_seconds = 300 # 5 minutes
# Incremental posture-counter tail cadence (only used when
# dataconnect.posture_event_counters is enabled). Cheap tail; short for fresh rates.
posture_counters_seconds = 300 # 5 minutes
# Incremental authentication-counter tail cadence (only used when
# dataconnect.authentication_event_counters is enabled). Cheap tail; short for fresh rates.
authentication_counters_seconds = 300 # 5 minutes
# Incremental error-counter tail cadence (only used when
# dataconnect.error_event_counters is enabled). Cheap tail; short for fresh rates.
error_counters_seconds = 300 # 5 minutes
# Historical posture assessments.
posture_seconds = 21600 # 6 hours
# Endpoint inventory follows its six-hour dashboard cadence. The cross-view
# source-freshness diagnostic remains daily.
endpoints_seconds = 21600 # 6 hours
freshness_seconds = 86400 # 1 day
# NAD health and TACACS activity/configuration correlations.
nad_health_seconds = 21600 # 6 hours
tacacs_seconds = 21600 # 6 hours

[endpoint_fleet]
# Opt-in accumulator. Keeps each endpoint's latest posture assessment in the
# restart-persistent state cache so fleet coverage/compliance accumulate toward
# the whole posture-applicable population over a day or two, instead of resetting
# to the bounded 6h reporting window or the capped 1000-session MnT sample.
# Data Connect only; MAC addresses stay in the private cache and are never labels.
# Disabled by default; requires a persistent, writable exporter.state_db.
enabled = false
# How often to pull recent assessments and recompute fleet aggregates.
interval_seconds = 900 # 15 minutes
# Drop an endpoint's cached posture once its latest assessment ages past this.
retention_seconds = 7776000 # 90 days
# Per-scan cap on assessments folded into the cache. The default comfortably
# covers steady re-posture rates. A mass re-posture (patch push) can exceed it,
# setting ise_endpoint_fleet_scan_truncated to 1. Later cycles pick up newly
# assessed endpoints, but if the fleet keeps re-posturing faster than the cap the
# oldest endpoints stay starved and coverage stays understated. If that flag stays
# set, raise this above your per-interval re-posture volume.
max_rows = 6000

[cli]
# Require explicit --allow-expensive for broad production queries.
production_safe = true
# Global escape hatch. Leave false and opt in per command when necessary.
allow_expensive = false
# Absolute default ceiling for CLI rows; individual commands may use lower defaults.
max_rows = 1000

[pxgrid]
# pxGrid 2.0 operator access is CLI-only; it does not enable exporter collectors.
host = "ise1.example.com"
port = 8910
node_name = "ise-cli"
# Prefer ISE_PXGRID_PASSWORD from a production secret manager. Certificate
# authentication is also supported by setting client_cert and client_key together.
password = "changeme"
client_cert = ""
client_key = ""
verify_tls = true
ca_bundle = "/etc/ise-exporter/certs/ise-ca.cer"
# Every control or service request is hard-capped at 30 seconds.
request_timeout_seconds = 30
