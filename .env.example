# Cisco ISE 3.3.0.430 Patch 11 production baseline (up to 100,000 endpoints).
# The exporter intentionally supports exactly this release and validates it at startup.

# --- logging ---
# DEBUG surfaces per-request REST and Data Connect query traffic.
LOG_LEVEL=INFO

# --- ISE REST (always required) ---
# PAN/ERS/OpenAPI calls use ISE_HOST. Bounded current active-session posture and
# ise-cli diagnostics use ISE_MNT_HOST; it is also the Data Connect default.
ISE_HOST=pan1.example.mil
ISE_MNT_HOST=mnt1.example.mil
ISE_USER=ers.readonly
# Everything after the first = is the value. It is loaded literally (no ${VAR}
# expansion); quote values that contain spaces or a # preceded by whitespace.
ISE_PASS=changeme
ERS_PORT=9060
# Verify REST/OpenAPI and bounded MnT HTTPS in production. The two planes
# may use different issuing CAs. Use false only for an isolated lab.
ISE_REST_SSL_VERIFY=true
ISE_REST_CA_BUNDLE=/etc/ise-exporter/certs/ise-rest-ca.pem
ISE_MNT_SSL_VERIFY=true
ISE_MNT_CA_BUNDLE=/etc/ise-exporter/certs/ise-mnt-ca.pem
EXPORTER_PORT=9618
# Private restart-persistent MnT cache, RADIUS rollups, and Data Connect metric snapshots.
ISE_EXPORTER_STATE_DB=/var/lib/ise-exporter/state.sqlite3

# --- scheduling / production load bounds ---
# Data Connect has its own conservative per-domain schedules below. These legacy
# tiers cover REST/config collectors and are intentionally not sub-minute.
SCRAPE_INTERVAL=60
FAST_INTERVAL=300
MEDIUM_INTERVAL=900
SLOW_INTERVAL=21600
MAX_WORKERS=8
DEVICE_CACHE_TTL=21600
AUTH_FAILURE_THRESHOLD=3
AUTH_FAILURE_BACKOFF=900

# --- maximum collection ---
COLLECT_DEVICE_DETAILS=true
COLLECT_CERTIFICATES=true
COLLECT_LICENSING=true
COLLECT_BACKUP_STATUS=true
COLLECT_PATCHES=true
COLLECT_TACACS=true
# Bounded current posture fills the ISE 3.3 reporting-view gap without turning
# MnT into a general reporting fallback. At this baseline, no more than 1,000
# unique active MAC details are considered every 15 minutes with two workers.
COLLECT_MNT_ACTIVE_POSTURE=true
MNT_ACTIVE_POSTURE_INTERVAL=900
MNT_ACTIVE_POSTURE_MAX_SESSIONS=1000
MNT_ACTIVE_POSTURE_WORKERS=2
MNT_ACTIVE_POSTURE_MAX_REQUESTS_PER_CYCLE=250
MNT_ACTIVE_POSTURE_REFRESH_TTL=3600
MNT_ACTIVE_POSTURE_REQUEST_INTERVAL_MS=500
TACACS_INTERNAL_USER_MAX=1000
# Review enabled accounts with neither an object change nor exporter-observed TACACS
# activity in this many days. The private state DB retains at most three high-water
# timestamps per configured internal account; it never copies raw MnT event history.
TACACS_UNUSED_ACCOUNT_DAYS=180
# Data Connect is the sole reporting plane for RADIUS, endpoints, posture, PSN
# performance, diagnostics, and TACACS activity.
ISE_DATACONNECT_HOST=mnt1.example.mil
ISE_DATACONNECT_PORT=2484
ISE_DATACONNECT_SERVICE=cpm10
ISE_DATACONNECT_USER=dataconnect
ISE_DATACONNECT_PASSWORD=changeme
ISE_DATACONNECT_CA_BUNDLE=/etc/ise-exporter/certs/ise-ca.cer
ISE_DATACONNECT_SSL_VERIFY=true
ISE_DATACONNECT_QUERY_TIMEOUT=15
# Low-pressure runtime guardrails for a production cluster: two-second statement
# pacing, a 0.5% adaptive duty-cycle ceiling, and at most 1,000 grouped rows.
ISE_DATACONNECT_MIN_QUERY_INTERVAL_MS=2000
ISE_DATACONNECT_MAX_DUTY_CYCLE_PERCENT=0.5
ISE_DATACONNECT_MAX_GROUPS=1000
ISE_DATACONNECT_SHARED_PACING_FILE=/var/lib/ise-exporter/dataconnect.pacing
# Per-domain production cadences. Data Connect work can affect other ISE personas
# even when the TCPS connection terminates on the secondary MnT.
ISE_DATACONNECT_RADIUS_INTERVAL=1800
ISE_DATACONNECT_PERFORMANCE_INTERVAL=3600
ISE_DATACONNECT_POSTURE_INTERVAL=21600
ISE_DATACONNECT_ENDPOINTS_INTERVAL=86400
ISE_DATACONNECT_FRESHNESS_INTERVAL=43200
ISE_DATACONNECT_NAD_HEALTH_INTERVAL=21600
ISE_DATACONNECT_TACACS_INTERVAL=21600
# Persist bounded aggregate windows locally so normal 30-minute runs scan only
# new RADIUS events. A full two-day reconciliation repairs late/missed rows daily.
ISE_DATACONNECT_INCREMENTAL_ENABLED=true
ISE_DATACONNECT_RECONCILE_INTERVAL=86400
ISE_DATACONNECT_MAX_BACKFILL_SECONDS=3600

# --- operator CLI production guardrails ---
# Broad leading-wildcard searches, full inventory enumeration, and MnT ActiveList
# scans require explicit command-line acknowledgement. Keep the global bypass off.
ISE_CLI_PRODUCTION_SAFE=true
ISE_CLI_ALLOW_EXPENSIVE=false
ISE_CLI_MAX_ROWS=1000
