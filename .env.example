# Cisco ISE 3.3.0.430 Patch 11 production baseline (up to 100,000 endpoints).
# The exporter intentionally supports exactly this release and validates it at startup.

# --- logging ---
# DEBUG surfaces per-request REST and Data Connect query traffic.
LOG_LEVEL=INFO

# --- ISE REST (always required) ---
# PAN/ERS/OpenAPI calls use ISE_HOST. Bounded current active-session posture and
# ise-cli diagnostics use ISE_MNT_HOST. Data Connect has a separate mandatory
# target below and never inherits either REST host.
ISE_HOST=pan1.example.mil
ISE_MNT_HOST=mnt1.example.mil
ISE_USER=ers.readonly
# Everything after the first = is the value. It is loaded literally (no ${VAR}
# expansion); quote values that contain spaces or a # preceded by whitespace.
ISE_PASS=changeme
ERS_PORT=9060
# Verify REST/OpenAPI and bounded MnT HTTPS in production. The two planes
# may use different issuing CAs. Use false only for an isolated lab.
ISE_REST_SSL_VERIFY=true
ISE_REST_CA_BUNDLE=/etc/ise-exporter/certs/ise-rest-ca.pem
ISE_MNT_SSL_VERIFY=true
ISE_MNT_CA_BUNDLE=/etc/ise-exporter/certs/ise-mnt-ca.pem
EXPORTER_PORT=9618
# Private restart-persistent MnT cache, RADIUS rollups, and Data Connect metric snapshots.
ISE_EXPORTER_STATE_DB=/var/lib/ise-exporter/state.sqlite3

# --- scheduling / production load bounds ---
# Data Connect has its own conservative per-domain schedules below. These legacy
# tiers cover REST/config collectors and are intentionally not sub-minute.
SCRAPE_INTERVAL=60
MEDIUM_INTERVAL=900
SLOW_INTERVAL=21600
# Space the first attempt for each enabled dataset across all collection planes.
# This prevents a service restart from creating a PAN, MnT, and Data Connect
# request burst. Set 0 to disable; normal recurring cadences are unaffected.
ISE_STARTUP_RATE_LIMIT_SECONDS=5
# NAD group detail is a low-volatility configuration dataset. Persist only the
# sanitized group list for 30 days and converge at no more than 25 serial PAN
# detail requests per six-hour cycle (roughly one request every 250 ms).
DEVICE_CACHE_TTL=2592000
DEVICE_DETAIL_MAX_REQUESTS=25
DEVICE_DETAIL_REQUEST_INTERVAL_MS=250
AUTH_FAILURE_THRESHOLD=3
ISE_REST_AUTH_GUARD_FILE=/var/lib/ise-exporter/shared/rest-auth.guard
AUTH_FAILURE_BACKOFF=900

# --- maximum collection ---
COLLECT_DEVICE_DETAILS=true
COLLECT_CERTIFICATES=true
COLLECT_LICENSING=true
COLLECT_BACKUP_STATUS=true
COLLECT_PATCHES=true
COLLECT_TACACS=true
# Bounded current posture fills the ISE 3.3 reporting-view gap without turning
# MnT into a general reporting fallback. At this baseline, no more than 1,000
# unique active MAC details are considered every 15 minutes with two workers.
COLLECT_MNT_ACTIVE_POSTURE=true
MNT_ACTIVE_POSTURE_INTERVAL=900
# ActiveList is unpaged. Refuse to download it when the cheap ActiveCount
# preflight exceeds this production ceiling.
MNT_ACTIVE_POSTURE_MAX_ACTIVE_LIST_SESSIONS=10000
MNT_ACTIVE_POSTURE_MAX_SESSIONS=1000
MNT_ACTIVE_POSTURE_WORKERS=2
MNT_ACTIVE_POSTURE_MAX_REQUESTS_PER_CYCLE=250
MNT_ACTIVE_POSTURE_REFRESH_TTL=3600
MNT_ACTIVE_POSTURE_REQUEST_INTERVAL_MS=500
TACACS_INTERNAL_USER_MAX=1000
# ERS exposes hygiene fields only on per-user detail resources. Persist those
# bounded details for seven days and refresh no more than 100 serial requests in
# one six-hour cycle, so a large account inventory cannot monopolize REST.
TACACS_INTERNAL_USER_DETAIL_MAX_REQUESTS=100
TACACS_INTERNAL_USER_DETAIL_TTL=604800
TACACS_INTERNAL_USER_DETAIL_REQUEST_INTERVAL_MS=250
# Device Admin rule lists require two PAN requests per policy set on ISE 3.3.
# Cache complete pairs and refresh at most ten policy sets per cycle.
TACACS_POLICY_SET_MAX=100
TACACS_POLICY_RULE_REFRESH_MAX=10
TACACS_POLICY_RULE_TTL=604800
TACACS_POLICY_RULE_REQUEST_INTERVAL_MS=250
# Review enabled accounts with neither an object change nor exporter-observed TACACS
# activity in this many days. The private state DB retains at most three high-water
# timestamps per configured internal account; it never copies raw MnT event history.
TACACS_UNUSED_ACCOUNT_DAYS=180
# Data Connect is the sole reporting plane for RADIUS, endpoints, posture, PSN
# performance, diagnostics, and TACACS activity.
# Required when Data Connect is enabled. This never inherits ISE_MNT_HOST: name
# the intended Data Connect node explicitly so XML and Oracle routing cannot be
# coupled accidentally. Prefer the deployment's designated secondary MnT.
ISE_DATACONNECT_HOST=mnt1.example.mil
ISE_DATACONNECT_PORT=2484
ISE_DATACONNECT_SERVICE=cpm10
ISE_DATACONNECT_USER=dataconnect
ISE_DATACONNECT_PASSWORD=changeme
ISE_DATACONNECT_CA_BUNDLE=/etc/ise-exporter/certs/ise-ca.cer
ISE_DATACONNECT_SSL_VERIFY=true
ISE_DATACONNECT_QUERY_TIMEOUT=15
# Low-pressure runtime guardrails for an 80-200GB production MnT: five-second
# statement pacing, a 0.1% adaptive duty-cycle ceiling, and at most 1,000 groups.
# The client also hard-caps every Oracle call at 15 seconds and the recurring
# active-session accounting scan at 60 minutes, regardless of caller configuration.
ISE_DATACONNECT_MIN_QUERY_INTERVAL_MS=5000
ISE_DATACONNECT_MAX_DUTY_CYCLE_PERCENT=0.1
ISE_DATACONNECT_MAX_GROUPS=1000
# Scheduled event aggregates follow their cadence up to this hard six-hour
# ceiling. A result row cap does not limit Oracle scan/group work. Daily domains
# deliberately sample six hours rather than scanning a full day on an 80-200GB MnT.
ISE_DATACONNECT_EVENT_WINDOW_HOURS=6
ISE_DATACONNECT_SHARED_PACING_FILE=/var/lib/ise-exporter/shared/dataconnect.pacing
ISE_DATACONNECT_AUTH_GUARD_FILE=/var/lib/ise-exporter/shared/dataconnect-auth.guard
# Per-domain production cadences. Data Connect work can affect other ISE personas
# even when the TCPS connection terminates on the secondary MnT.
# RADIUS reporting is deliberately daily and samples at most six hours. The
# bounded active-session reconstruction runs every two hours; other large event
# domains run every six hours or daily.
ISE_DATACONNECT_RADIUS_INTERVAL=86400
ISE_DATACONNECT_RADIUS_ACTIVE_INTERVAL=7200
ISE_DATACONNECT_PERFORMANCE_INTERVAL=21600
ISE_DATACONNECT_POSTURE_INTERVAL=86400
ISE_DATACONNECT_ENDPOINTS_INTERVAL=86400
ISE_DATACONNECT_FRESHNESS_INTERVAL=86400
ISE_DATACONNECT_NAD_HEALTH_INTERVAL=86400
ISE_DATACONNECT_TACACS_INTERVAL=86400
# --- operator CLI production guardrails ---
# Broad leading-wildcard searches, full inventory enumeration, and MnT ActiveList
# scans require explicit command-line acknowledgement. Keep the global bypass off.
ISE_CLI_PRODUCTION_SAFE=true
ISE_CLI_ALLOW_EXPENSIVE=false
ISE_CLI_MAX_ROWS=1000
