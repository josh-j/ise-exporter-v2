# Cisco ISE 3.3 production baseline (~80,000 endpoints).
# This enables every collector while bounding the expensive per-endpoint/MnT fan-out.

# --- logging ---
# DEBUG surfaces per-request pxGrid control/query traffic.
LOG_LEVEL=INFO

# --- ISE REST (always required) ---
# PAN/ERS/OpenAPI calls use ISE_HOST; MnT Session/AuthStatus calls use ISE_MNT_HOST.
ISE_HOST=pan1.example.mil
ISE_MNT_HOST=mnt1.example.mil
ISE_USER=ers.readonly
# Everything after the first = is the value. It is loaded literally (no ${VAR}
# expansion); quote values that contain spaces or a # preceded by whitespace.
ISE_PASS=changeme
ERS_PORT=9060
EXPORTER_PORT=9618

# --- scheduling / production load bounds ---
# At 1,000 endpoint details/hour, a full 80k ERS pass takes ~80 hours, comfortably
# inside the 7-day cache TTL. Authz can warm at most 1,000 new sessions/5 minutes;
# steady-state sessions are served from the 24-hour in-process cache.
SCRAPE_INTERVAL=60
FAST_INTERVAL=60
MEDIUM_INTERVAL=300
SLOW_INTERVAL=3600
MAX_WORKERS=12
DEVICE_CACHE_TTL=21600
SESSION_DETAIL_CACHE_TTL=86400
MAX_DETAIL_FETCHES_PER_CYCLE=1000
RECENT_AUTH_STATUS_MAX=250
AUTH_FAILURE_THRESHOLD=3
AUTH_FAILURE_BACKOFF=900

# --- maximum collection ---
COLLECT_DEVICE_DETAILS=true
COLLECT_CERTIFICATES=true
COLLECT_LICENSING=true
COLLECT_BACKUP_STATUS=true
COLLECT_PATCHES=true
COLLECT_AUTHZ=true
COLLECT_TACACS=true
TACACS_INTERNAL_USER_MAX=1000
# Optional getEndpoints enrichment; often empty on ISE 3.3.
COLLECT_PXGRID_ENDPOINTS=true
# Preferred at 80k: topics reduce repeated session polling.
COLLECT_PXGRID_STREAM=true
# The richer endpoint-detail collector below owns the ERS baseline.
COLLECT_ERS_ENDPOINT_FALLBACK=false
# Used only if the legacy fallback above is enabled.
ERS_ENDPOINT_PROFILE_MAX=1500
# Slow cached /ers/config/endpoint/{id} detail sweep.
COLLECT_ERS_ENDPOINT_ATTRIBUTES=true
# Endpoints refreshed per hourly slow cycle.
ERS_ENDPOINT_ATTRIBUTE_PAGE_SIZE=1000
ERS_ENDPOINT_ATTRIBUTE_CACHE_TTL=604800
ERS_ENDPOINT_ATTRIBUTE_CACHE_FILE=/var/lib/ise-exporter/endpoint-attributes-cache.json
ERS_ENDPOINT_ATTRIBUTE_VALUE_MAX_LEN=80
# Exact, comma-separated ISE custom-attribute names. Quotes safely preserve spaces
# under both systemd EnvironmentFile= and python-dotenv.
ERS_ENDPOINT_CUSTOM_ATTRIBUTE_KEYS="Ops Owner"

# --- pxGrid (model collector + streaming) ---
PXGRID_HOST=pxgrid1.example.mil
PXGRID_PORT=8910
PXGRID_NODE_NAME=ise-exporter
PXGRID_CLIENT_CERT=/certs/client.cer
PXGRID_CLIENT_KEY=/certs/client.key
PXGRID_CA_BUNDLE=/certs/ise-ca.cer
PXGRID_MIN_COUNT=1
PXGRID_QUERY_TIMEOUT=120
PXGRID_PROJECT_INTERVAL=30
PXGRID_RESYNC_INTERVAL=3600
PXGRID_WATCHDOG_TIMEOUT=90
PXGRID_RECONNECT_MAX_BACKOFF=60
# Profiler policy catalog refresh cadence.
PXGRID_PROFILER_HIERARCHY_TTL=3600
# Retry cadence after getEndpoints returns zero endpoints.
PXGRID_ENDPOINT_ZERO_BACKOFF=3600
# Opt into sessionTopicAll only on ISE 3.3p2/3.4+ and when its group is authorized.
PXGRID_SESSION_TOPIC_ALL=false
# Keep false: getEndpoints REST provides endpoint enrichment without requiring the
# endpoint pubsub policy.
PXGRID_SUBSCRIBE_ENDPOINT_TOPIC=false
# Avoid re-downloading a potentially large endpoint snapshot every 15 minutes.
PXGRID_ENDPOINT_REFRESH_INTERVAL=3600
