# --- ISE REST (always required) ---
ISE_HOST=pan1.example.mil
ISE_MNT_HOST=mnt1.example.mil
ISE_USER=ers.readonly
ISE_PASS=changeme
EXPORTER_PORT=9618

# --- scheduling tiers ---
SCRAPE_INTERVAL=120
FAST_INTERVAL=60
MEDIUM_INTERVAL=300
SLOW_INTERVAL=3600
MAX_WORKERS=10

# --- collector toggles ---
COLLECT_AUTHZ=true
COLLECT_PXGRID_ENDPOINTS=true     # bulk getEndpoints model breakdown
COLLECT_PXGRID_STREAM=false       # set true to replace sessions+authz polling with topics

# --- pxGrid (model collector + streaming) ---
PXGRID_HOST=pxgrid1.example.mil
PXGRID_NODE_NAME=ise-exporter
PXGRID_CLIENT_CERT=/certs/client.cer
PXGRID_CLIENT_KEY=/certs/client.key
PXGRID_CA_BUNDLE=/certs/ise-ca.cer
PXGRID_PROJECT_INTERVAL=30
PXGRID_RESYNC_INTERVAL=3600
