# Cisco ISE 3.3 production baseline (~80,000 endpoints).
# This enables every collector while bounding the expensive per-endpoint/MnT fan-out.

# --- logging ---
LOG_LEVEL=INFO                    # DEBUG surfaces per-request pxGrid control/query traffic

# --- ISE REST (always required) ---
ISE_HOST=pan1.example.mil
ISE_MNT_HOST=mnt1.example.mil
ISE_USER=ers.readonly
# Everything after the first = is the value. It is loaded literally (no ${VAR}
# expansion); quote values that contain spaces or a # preceded by whitespace.
ISE_PASS=changeme
ERS_PORT=9060
EXPORTER_PORT=9618

# --- scheduling / production load bounds ---
# At 1,000 endpoint details/hour, a full 80k ERS pass takes ~80 hours, comfortably
# inside the 7-day cache TTL. Authz can warm at most 1,000 new sessions/5 minutes;
# steady-state sessions are served from the 24-hour in-process cache.
SCRAPE_INTERVAL=60
FAST_INTERVAL=60
MEDIUM_INTERVAL=300
SLOW_INTERVAL=3600
MAX_WORKERS=12
DEVICE_CACHE_TTL=21600
SESSION_DETAIL_CACHE_TTL=86400
MAX_DETAIL_FETCHES_PER_CYCLE=1000
RECENT_AUTH_STATUS_MAX=250
AUTH_FAILURE_THRESHOLD=3
AUTH_FAILURE_BACKOFF=900

# --- maximum collection ---
COLLECT_DEVICE_DETAILS=true
COLLECT_CERTIFICATES=true
COLLECT_LICENSING=true
COLLECT_BACKUP_STATUS=true
COLLECT_PATCHES=true
COLLECT_AUTHZ=true
COLLECT_TACACS=true
TACACS_INTERNAL_USER_MAX=1000
COLLECT_PXGRID_ENDPOINTS=true     # optional getEndpoints enrichment; often empty on ISE 3.3
COLLECT_PXGRID_STREAM=true        # preferred at 80k: topics reduce repeated session polling
COLLECT_ERS_ENDPOINT_FALLBACK=false # richer endpoint-detail collector below owns baseline
ERS_ENDPOINT_PROFILE_MAX=1500     # used only if the legacy fallback above is enabled
COLLECT_ERS_ENDPOINT_ATTRIBUTES=true  # slow cached /ers/config/endpoint/{id} detail sweep
ERS_ENDPOINT_ATTRIBUTE_PAGE_SIZE=1000 # endpoints refreshed per hourly slow cycle
ERS_ENDPOINT_ATTRIBUTE_CACHE_TTL=604800
ERS_ENDPOINT_ATTRIBUTE_CACHE_FILE=/var/lib/ise-exporter/endpoint-attributes-cache.json
ERS_ENDPOINT_ATTRIBUTE_VALUE_MAX_LEN=80
ERS_ENDPOINT_CUSTOM_ATTRIBUTE_KEYS=   # optional comma-list, e.g. asset_tag,ops_owner

# --- pxGrid (model collector + streaming) ---
PXGRID_HOST=pxgrid1.example.mil
PXGRID_PORT=8910
PXGRID_NODE_NAME=ise-exporter
PXGRID_CLIENT_CERT=/certs/client.cer
PXGRID_CLIENT_KEY=/certs/client.key
PXGRID_CA_BUNDLE=/certs/ise-ca.cer
PXGRID_MIN_COUNT=1
PXGRID_QUERY_TIMEOUT=120
PXGRID_PROJECT_INTERVAL=30
PXGRID_RESYNC_INTERVAL=3600
PXGRID_WATCHDOG_TIMEOUT=90
PXGRID_RECONNECT_MAX_BACKOFF=60
PXGRID_PROFILER_HIERARCHY_TTL=3600  # re-fetch the profiler policy catalog (category/parent) at most this often
PXGRID_ENDPOINT_ZERO_BACKOFF=3600    # retry getEndpoints this often after an empty result
PXGRID_SESSION_TOPIC_ALL=false      # true = subscribe sessionTopicAll (.session.all); needs ISE 3.3p2/3.4+ and group authorized for it
PXGRID_SUBSCRIBE_ENDPOINT_TOPIC=false  # false = endpoint attrs (models/profiles/posture) via getEndpoints REST poll; true = also subscribe the live endpoint topic (needs pubsub subscribe policy)
PXGRID_ENDPOINT_REFRESH_INTERVAL=3600  # avoid re-downloading a large endpoint snapshot every 15 minutes
