#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PSModulePath="${SCRIPT_DIR}${PSModulePath:+:${PSModulePath}}"
PROFILE="${SCRIPT_DIR}/Ise.Cli.Profile.ps1"

run_backend() {
    if [[ -n "${ISE_CLI_BACKEND:-}" && -x "${ISE_CLI_BACKEND}" ]]; then
        exec "${ISE_CLI_BACKEND}" "$@"
    fi
    INSTALLED_BACKEND="${SCRIPT_DIR}/../.venv/bin/ise-cli-backend"
    if [[ -x "$INSTALLED_BACKEND" ]]; then
        exec "$INSTALLED_BACKEND" "$@"
    fi
    if command -v ise-cli-backend >/dev/null 2>&1; then
        exec ise-cli-backend "$@"
    fi
    echo "ise-cli-backend is not installed or executable" >&2
    exit 127
}

if [[ "${ISE_CLI_FORCE_BACKEND:-0}" == 1 && $# -gt 0 ]]; then
    run_backend "$@"
fi

if ! command -v pwsh >/dev/null 2>&1; then
    if [[ $# -eq 0 ]]; then
        echo "interactive ise-cli requires PowerShell 7 (pwsh)" >&2
        echo "non-interactive commands remain available: ise-cli COMMAND --help" >&2
        exit 127
    fi
    run_backend "$@"
fi

if [[ $# -eq 0 ]]; then
    exec pwsh -NoLogo -NoProfile -NoExit -File "$PROFILE"
fi

# PowerShell binds abbreviated common parameters before a script's
# ValueFromRemainingArguments parameter sees them. Normalize the native CLI's
# short options here so `ise-cli ... -o json` and `-v` stay backend arguments.
NORMALIZED_ARGS=()
for argument in "$@"; do
    case "$argument" in
        -o) NORMALIZED_ARGS+=(--output) ;;
        -v) NORMALIZED_ARGS+=(--version) ;;
        *) NORMALIZED_ARGS+=("$argument") ;;
    esac
done
exec pwsh -NoLogo -NoProfile -File "${SCRIPT_DIR}/ise-cli.ps1" "${NORMALIZED_ARGS[@]}"
