#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PSModulePath="${SCRIPT_DIR}${PSModulePath:+:${PSModulePath}}"
PROFILE="${SCRIPT_DIR}/Ise.Cli.Profile.ps1"

if ! command -v pwsh >/dev/null 2>&1; then
    echo "ise-cli requires PowerShell 7 (pwsh); the exporter service does not" >&2
    exit 127
fi

if [[ $# -eq 0 ]]; then
    exec pwsh -NoLogo -NoProfile -NoExit -File "$PROFILE"
fi

exec pwsh -NoLogo -NoProfile -File "${SCRIPT_DIR}/ise-cli.ps1" "$@"
