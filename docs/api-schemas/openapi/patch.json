    "/api/v1/patch/install": {
      "post": {
        "tags": [
          "Patching"
        ],
        "summary": "Trigger patch installation on the Cisco ISE node.",
        "description": "Triggers patch installation on the Cisco ISE node. A task ID is returned which can be used to monitor the progress of the patch installation process. As the patch   installation triggers the Cisco ISE to restart, the task API becomes unavailable for  a certain period of time. For installation of patch on secondary nodes, request needs  to be sent to individual node instead of the Primary Administration Node. ",
        "operationId": "installPatch",
        "parameters": [
          {
            "name": "X-Request-ID",
