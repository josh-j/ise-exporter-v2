              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse",
                  "exampleSetFlag": false
                }
              }
            }
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      }
    },
