    "/api/v1/integration-catalog/applications/pxgrid-cloud/{id}/issue-otp": {
      "post": {
        "tags": [
          "Integration Catalog"
        ],
        "summary": "Generate OTP for a pxGrid Cloud application",
        "description": "Generate OTP of the pxGrid Cloud application for the given `id`.",
        "operationId": "issueApplicationOtp",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of an application.",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "exampleSetFlag": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Application OTP",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplicationOtpResponse",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Resource Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "409": {
            "description": "Resource Conflict - Tenant is already subscribed to the application",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Application": {
        "title": "Application",
        "required": [
          "availableScopes",
          "categories",
          "id",
          "instantiable",
          "lastUsed",
          "name",
          "regions",
          "status",
          "tenantAppActivationStatus"
        ],
        "type": "object",
        "properties": {
          "appLogoImage": {
            "type": "string",
            "description": "Location of the application logo image.",
            "example": "https://cdn.cookielaw.org/logos/03fc55fe-0057-4b2f-817d-763e7ecdb316/a7f4c642-c43c-4666-acea-858c0449029c/cisco-logo-transparent.png",
            "exampleSetFlag": true
          },
          "availableScopes": {
            "type": "array",
            "description": "List of scopes published by the application.",
            "exampleSetFlag": true,
            "items": {
              "$ref": "#/components/schemas/Scope",
              "exampleSetFlag": false
            }
          },
          "categories": {
            "type": "array",
            "description": "Categories of the application.",
            "example": "[\"Network Security\",\"pxGrid cloud\"]",
            "exampleSetFlag": true,
            "items": {
              "type": "string",
              "exampleSetFlag": false
            }
          },
          "description": {
            "type": "string",
            "description": "Description of the application.",
            "example": "Firepower Management Center (FMC) integrates with Cisco ISE to provide user identity based access policy.",
            "exampleSetFlag": true
          },
          "id": {
            "type": "string",
            "description": "Unique application id.",
            "example": "fmcmi-pxgrid",
            "exampleSetFlag": true
          },
          "instances": {
            "type": "array",
            "description": "List of child application instances.",
            "exampleSetFlag": true,
            "items": {
              "$ref": "#/components/schemas/Application",
              "exampleSetFlag": false
            }
          },
          "instantiable": {
            "type": "boolean",
            "description": "Flag to indicate whether the application supports multiple instances or not.",
            "example": true,
            "exampleSetFlag": true
          },
          "lastUsed": {
            "type": "boolean",
            "description": "Flag to indicate whether the instance of application recently used by user or not.",
            "example": true,
            "exampleSetFlag": true
          },
          "linkedScopes": {
            "type": "array",
            "description": "List of scopes which have been activated for this application on the device. This will have value only after application is activated.",
            "example": "[\"session\"]",
            "exampleSetFlag": true,
            "items": {
              "type": "string",
              "exampleSetFlag": false,
              "enum": [
                "anc",
                "echo",
                "endpoint",
                "mdm",
                "profiler",
                "radius",
                "session",
                "trustsec",
                "udn"
              ]
            }
          },
          "name": {
            "type": "string",
            "description": "Name of the application.",
            "example": "Firewall Management Center",
            "exampleSetFlag": true
          },
          "profile": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "exampleSetFlag": false
            },
            "example": "{\"token_redeem_url\":\"https://myapp.vendor.com/redeemOtp\"}",
            "exampleSetFlag": true
          },
          "regions": {
            "type": "array",
            "description": "List of regions where the application is available.",
            "example": "[\"us-west-2\"]",
            "exampleSetFlag": true,
            "items": {
              "type": "string",
              "exampleSetFlag": false
            }
          },
          "status": {
            "type": "string",
            "description": "Activation status of the application.",
            "example": "Activated",
            "exampleSetFlag": true,
            "enum": [
              "Activated",
              "Activating",
              "Activation Failure",
              "Activation Unresponsive",
              "Deactivating",
              "Deactivation Failure",
              "Deactivation Unresponsive",
              "Not Activated",
              "pending"
            ]
          },
          "tenantAppActivationStatus": {
            "type": "boolean",
            "description": "Flag to indicate whether the application has been activated for the tenant or not.",
            "example": true,
            "exampleSetFlag": true
          },
          "vendor": {
            "type": "string",
            "description": "Vendor of the application.",
            "example": "Cisco Firepower (Cisco Secure Firewall)",
            "exampleSetFlag": true
          }
        },
        "description": "Object which describe the attributes of an cloud application.",
        "exampleSetFlag": false
      },
      "ApplicationListResponse": {
        "title": "ApplicationListResponse",
        "type": "object",
        "properties": {
          "applications": {
            "type": "array",
            "description": "List of the applications.",
            "exampleSetFlag": true,
            "items": {
              "$ref": "#/components/schemas/Application",
              "exampleSetFlag": false
            }
          },
          "errors": {
            "type": "array",
            "description": "List of errors while fetching the applications.",
            "exampleSetFlag": true,
            "items": {
              "type": "string",
              "exampleSetFlag": false
            }
          }
        },
        "description": "List of applications and errors.",
        "exampleSetFlag": false
      },
      "ApplicationOtpResponse": {
        "title": "ApplicationOtpResponse",
        "required": [
          "version"
        ],
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "example": "{\"otp\":\"fllXnWacP3D1ivxn84btAMApvsAytYNtvhkOIPad2h5mQLf6FTHo8PEa8kqqzXVB\"}",
            "exampleSetFlag": true
          },
          "version": {
            "type": "string",
            "description": "Version of the API response.",
            "example": "1.0.0",
            "exampleSetFlag": true
          }
        },
        "description": "Response containing application OTP.",
        "exampleSetFlag": false
      },
      "ApplicationResponse": {
        "title": "ApplicationResponse",
        "required": [
          "version"
        ],
        "type": "object",
        "properties": {
          "response": {
            "$ref": "#/components/schemas/Application",
            "exampleSetFlag": true
          },
          "version": {
            "type": "string",
            "description": "Version of the API response.",
            "example": "1.0.0",
            "exampleSetFlag": true
          }
        },
        "description": "Response containing application details.",
        "exampleSetFlag": false
      },
      "ApplicationsResponse": {
        "title": "ApplicationsResponse",
        "required": [
          "version"
        ],
        "type": "object",
        "properties": {
          "response": {
            "$ref": "#/components/schemas/ApplicationListResponse",
            "exampleSetFlag": true
          },
          "version": {
            "type": "string",
            "description": "Version of the API response.",
            "example": "1.0.0",
            "exampleSetFlag": true
          }
        },
        "description": "Response containing list of applications.",
        "exampleSetFlag": false
      },
      "Error": {
        "title": "Error",
        "required": [
          "code",
          "message"
        ],
        "type": "object",
        "properties": {
          "arguments": {
            "type": "array",
            "description": "List of error arguments which can be used to replace dynamic fields when API fails.",
            "exampleSetFlag": true,
            "items": {
              "type": "string",
              "exampleSetFlag": false
            }
          },
          "code": {
            "type": "string",
            "description": "Unique error code when an API fails.",
            "example": "invalid.application.scope",
            "exampleSetFlag": true
          },
          "message": {
            "type": "string",
            "description": "Error message when an API fails.",
            "example": "Invalid application scope(s), possible scopes are: [anc, echo, endpoint, mdm, profiler, radius, session, trustsec, udn]",
            "exampleSetFlag": true
          }
        },
        "description": "Error details",
        "exampleSetFlag": false
      },
      "Scope": {
        "title": "Scope",
        "required": [
          "key"
        ],
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique key of the data scope of an application.",
            "example": "session",
            "exampleSetFlag": true
          }
        },
        "description": "Object which explain about scope of an application.",
        "exampleSetFlag": false
      }
    }
  }
}
