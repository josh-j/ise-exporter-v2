{
  "openapi": "3.0.3",
  "info": {
    "title": "Cisco ISE API - Integration Catalog",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://10.81.0.10:443",
      "description": "Inferred Url"
    }
  ],
  "tags": [
    {
      "name": "integration-catalog-api-controller",
      "description": "the integration-catalog API"
    }
  ],
  "paths": {
    "/api/v1/integration-catalog/applications": {
      "get": {
        "tags": [
          "Integration Catalog"
        ],
        "summary": "Get the list of applications",
        "description": "Returns the list of applications within the integration catalog.",
        "operationId": "getApplications",
        "responses": {
          "200": {
            "description": "List of applications.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplicationsResponse",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      }
    },
    "/api/v1/integration-catalog/applications/pxgrid-cloud/{id}": {
      "get": {
        "tags": [
          "Integration Catalog"
        ],
        "summary": "Get the details of a pxGrid Cloud application",
        "description": "Returns the details of a pxGrid Cloud application for the given `id`.",
        "operationId": "getApplication",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of an application.",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "exampleSetFlag": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Details of the application.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplicationResponse",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Resource Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      }
    },
    "/api/v1/integration-catalog/applications/pxgrid-cloud/{id}/activate": {
      "post": {
        "tags": [
          "Integration Catalog"
        ],
        "summary": "Activate a pxGrid Cloud application",
        "description": "Activate the given pxGrid Cloud application on the current ISE deployment.",
        "operationId": "activateApplication",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of an application.",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "exampleSetFlag": true
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "exampleSetFlag": true,
                "items": {
                  "type": "string",
                  "exampleSetFlag": false
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "Error-ModelName{namespace='java.lang', name='Void'}",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "201": {
            "description": "Created"
          },
          "202": {
            "description": "Accepted. Check `GET /integration-catalog/applications/pxgrid-cloud/{id}` API to fetch the activation details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "Error-ModelName{namespace='java.lang', name='Void'}",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Resource Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      }
    },
    "/api/v1/integration-catalog/applications/pxgrid-cloud/{id}/deactivate": {
      "post": {
        "tags": [
          "Integration Catalog"
        ],
        "summary": "Deactivate a pxGrid Cloud application",
        "description": "Deactivate the given pxGrid Cloud application on the current ISE deployment.",
        "operationId": "deactivateApplication",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of an application.",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string",
              "exampleSetFlag": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "201": {
            "description": "Created"
          },
          "202": {
            "description": "Accepted. Check `GET /integration-catalog/applications/pxgrid-cloud/{id}` API to fetch the deactivation details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "Error-ModelName{namespace='java.lang', name='Void'}",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Resource Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "exampleSetFlag": false
                }
              }
            }
          }
        },
        "security": [
          {
            "BasicAuth": []
          }
        ]
      }
